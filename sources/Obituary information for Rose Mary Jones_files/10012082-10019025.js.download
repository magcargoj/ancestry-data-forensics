ntact-us\"].CROTest001 { max-width: 400px; margin: 30px auto 0; }","js":function(convertContext){ 
function runCustomCode() {
  const heading = document.querySelector('section.fr-section.is-overlay .fr-col-box__inner h3');
  if (heading) {
    const link = document.createElement('a');
    link.href = "/contact/contact-us";
    link.className = "fr-btn fr-btn_default fr-node CROTest001";
    link.target = "_self";
    link.innerHTML = '<span class="fr-btn__text">Contact Us 24/7</span>';
    heading.insertAdjacentElement('afterend', link);
  } else {
    // Retry after 500ms
    setTimeout(runCustomCode, 500);
  }
}

// Run immediately after DOM is ready

if (document.readyState !== 'loading') {
  runCustomCode();
} else {
  document.addEventListener('DOMContentLoaded', runCustomCode);
}
