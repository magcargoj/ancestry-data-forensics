        const utils = window.optimizely.get("utils");

if (extension.selector) {
  utils.waitForElement(extension.selector).then(function (elem) {
    const country = window.ozly.getDataLayerValue("siteInfo.currency");
    const priceText = country === "CAD" ? "C$100" : "$100";

    const html = extension.$render({
      extension: extension,
      priceText
    });

    elem.insertAdjacentHTML(extension.insertType, html);
  });
}

$(function () {
  $(document).on(
    "click",
    `#optimizely-extension-${extension.$instance} button.btn-shop-now`,
    function () {
      const $this = $(this);
      const linkPrice = `-${$this.data("price")}.00`;
      const linkEle = $(
        `.price-range-filter a[data-value="${linkPrice}"]`
      ).closest("li");
      if (linkEle.length > 0) {
        linkEle.click();
      }

      if (typeof window.trackingShopNow === "function") {
        window.trackingShopNow();
      }
    }
  );
});

