76DEB-67A0-424B-B927-0EEDBC9C5BE5", "type": "custom_code", "value": function($){document.getElementsByTagName('html')[0].classList.add('CRO-142-active');
}, "dependencies": []}], "id": "28168890369", "name": "CRO-142 TCO | Obit | My Tribute Gift BHAG", "commitId": "30412230411", "groupId": null, "holdback": 0, "activation": {}, "integrationSettings": {"google_analytics_4": {"is_using_gtm": "on"}, "google_universal_analytics": {"universal_analytics_slot": "117", "universal_analytics_tracker": ""}}, "integrationStringVersion": 2, "experiments": [{"audienceIds": ["and", "28171850359", "27724250398", "28417170936", "30051410384", "30026211010"], "audienceName": "CRO-142 - FH target for MTG,Frazer/SRS template,Exclude Death Notice Obituaries,Exclusion FHs from CRO-1117,Exclusion Obituaries with TTC crowdfunding ", "changes": null, "id": "28169880321", "integrationSettings": null, "variations": [{"id": "28281350013", "name": "Variation #1", "actions": [{"viewId": "28201270515", "changes": [{"id": "1D118EB6-7AD4-44E8-8EB0-C86DF8C100FE", "type": "custom_code", "value": function($){const util = window.optimizely.get("utils");

const isMTG = (site) => {
  return site && site.indexOf("mytributegift") !== -1;
};

const convertToUTMparams = (href) => {
  const urlCls = href ? new URL(href) : "";
  let searchParams = "";
  if (urlCls) {
		const urlMTGparam = new URLSearchParams(urlCls.search);
    urlMTGparam.set("utm_source", encodeURIComponent(window.location.hostname.replace("www.", "")));
    urlMTGparam.set("utm_medium", "referral");
    urlMTGparam.set("utm_campaign", "Tribute-TCO-CRO-142");
    urlMTGparam.set("utm_content", "V1");
    urlMTGparam.set("istip", "yes");
    searchParams = `?${urlMTGparam.toString()}`;
    return `${urlCls.origin}${urlCls.pathname}${searchParams}`;
  }
  return href;
};

const renderElement = (element) => {
	const href = element.href || "";
  if (isMTG(href)) {
  	element.href = convertToUTMparams(href);
    element.classList.add("mtg-button");
    element.addEventListener("click", pushData);
  }
};

const pushData = () => {
	dataLayer.push({
    'event': 'ga4Event', 
    'category': 'Obit - Donate Now',
    'action': 'Obit - Donate Now click - #CRO-142 - V1',
    'label': 'Donate Now click - V1'
  });
};

const ctoWatchContributton = util.observeSelector('.memorial-contributon__item--link', renderElement);
const ctoWatchDonations = util.observeSelector('.donate-contribution-item__link', renderElement);

window.addEventListener('beforeunload', function (e) {
 if (ctoWatchContributton && typeof ctoWatchContributton === "function") {
   // remove event listener
   ctoWatchContributton();
 }
  
 if (ctoWatchDonations && typeof ctoWatchDonations === "function") {
   ctoWatchDonations();
 }
  
 const mtgButtons = document.querySelectorAll(".memorial-contributon__item--link.mtg-button, .donate-contribution-item__link.mtg-button");
 if (mtgButtons.length > 0) {
 	mtgButtons.forEach((item) => {
    item.removeEventListener("click", pushData);
   });
 } 
});
}, "dependencies": []}]}]}, {"id": "28222310206", "name": "Variation #2", "actions": [{"viewId": "28201270515", "changes": [{"id": "DC6F7633-70E5-4591-B625-5E9F0CD5BF43", "type": "custom_code", "value": function($){const util = window.optimizely.get("utils");

const isMTG = (site) => {
  return site && site.indexOf("mytributegift") !== -1;
};

const convertToUTMparams = (href) => {
  const urlCls = href ? new URL(href) : "";
  let searchParams = "";
  if (urlCls) {
		const urlMTGparam = new URLSearchParams(urlCls.search);
    urlMTGparam.set("utm_source", encodeURIComponent(window.location.hostname.replace("www.", "")));
    urlMTGparam.set("utm_medium", "referral");
    urlMTGparam.set("utm_campaign", "Tribute-TCO-CRO-142");
    urlMTGparam.set("utm_content", "V2");
    urlMTGparam.set("istip", "yes");
    searchParams = `?${urlMTGparam.toString()}`;
    return `${urlCls.origin}${urlCls.pathname}${searchParams}`;
  }
  return href;
};

const renderElement = (element) => {
	const href = element.href || "";
  if (isMTG(href)) {
  	element.href = convertToUTMparams(href);
    element.classList.add("mtg-button");
    element.addEventListener("click", pushData);
  }
};

const pushData = () => {
	dataLayer.push({
    'event': 'ga4Event', 
    'category': 'Obit - Donate Now',
    'action': 'Obit - Donate Now click - #CRO-142 - V2',
    'label': 'Donate Now click - V2'
  });
};

const ctoWatchContriItem = util.observeSelector('.memorial-contribution', (element) => {
    const memorial =  window.materialObit.$store.getters['GET_MEMORIALS'] || window.materialObit.$store.state.moduleEvents.memorials || [];
    const mtgKeys = memorial.reduce((prev, curr, currentIndex) => {
      return isMTG(curr.WebsiteAddress || "") ? [...prev, currentIndex] : [...prev];
    }, []);

    const $memorialItems = document.querySelectorAll(".memorial-contribution > .memorial-contributon__item");
    if (mtgKeys.length > 0) {
      element.classList.add("memorial-contribution__mtg");
    }

    if ($memorialItems.length > 0) {
      for (const key of mtgKeys) {
        let $memorialItem = $memorialItems[key];
        const $title = $memorialItem.querySelector(".memorial-contributon__item--name");
        $title.innerText = "Donate to Charity";

        const elementDescription = document.createElement("div");
        elementDescription.classList.add("memorial-contributon__item--description");
        elementDescription.innerText = `Keep ${window.MaterialData.user.firstName}’s legacy alive by donating to a charity in need.`;        
        $title.insertAdjacentElement("afterend", elementDescription);
      }
  	}
});

const ctoWatchdonateItem = util.observeSelector('.donation-contribution__list', (element) => {
    const memorial =  window.materialObit.$store.getters['GET_DONATE_MEMORIALS'] || window.materialObit.$store.state.moduleEvents.memorials || [];
    const mtgKeys = memorial.reduce((prev, curr, currentIndex) => {
      return isMTG(curr.WebsiteAddress || "") ? [...prev, currentIndex] : [...prev];
    }, []);

    const $memorialItems = document.querySelectorAll(".donation-contribution__list > .donate-contribution-item");
    if ($memorialItems.length > 0) {
      for (const key of mtgKeys) {
        let $memorialItem = $memorialItems[key];
        const description = $memorialItem.querySelector(".donate-contribution-item__description");
        if (description) {
        	description.innerText = `Keep ${window.MaterialData.user.firstName}’s legacy alive by donating to a charity in need.`; 
        }
      }
  	}
});

const ctoWatchContributton = util.observeSelector('.memorial-contributon__item--link', renderElement);
const ctoWatchDonations = util.observeSelector('.donate-contribution-item__link', renderElement);

window.addEventListener('beforeunload', function (e) {
 if (ctoWatchContributton && typeof ctoWatchContributton === "function") {
   // remove event listener
   ctoWatchContributton();
 }
  
 if (ctoWatchDonations && typeof ctoWatchDonations === "function") {
   // remove event listener
   ctoWatchDonations();
 }
  
 if (ctoWatchContriItem && typeof ctoWatchContriItem === "function") {
 	ctoWatchContriItem();
 }
 
 if (ctoWatchdonateItem && typeof ctoWatchdonateItem === "function") {
 	ctoWatchdonateItem();
 }

 const mtgButtons = document.querySelectorAll(".memorial-contributon__item--link.mtg-button .donate-contribution-item__link.mtg-button");
 if (mtgButtons.length > 0) {
 	mtgButtons.forEach((item) => {
    item.removeEventListener("click", pushData);
   });
 } 
});
