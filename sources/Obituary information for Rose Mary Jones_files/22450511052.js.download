}, "dependencies": []}, {"id": "fe869d67545049ac95effcc026d80f8f", "type": "append", "selector": "head", "value": "<style>.CRO-2763-active {\n  --gallery-space: 36px;\n  --space-between-sections: 48px;\n}\n\n.CRO-2763-active .ts-customizable-body {\n  padding-top: var(--space-between-sections);\n  width: 1440px;\n  max-width: 100%;\n}\n\n.CRO-2763-active .obituary-banner {\n  justify-content: center;\n  padding: 24px 0 0;\n  position: relative;\n  gap: var(--obitbanner-gap);\n}\n\n.CRO-2763-active .obituary-banner__content {\n  gap: 16px;\n}\n\n.CRO-2763-active .gallery-wrapper {\n  align-items: center;\n}\n\n.CRO-2763-active .gallery-wrapper .gallery {\n  width: 100%;\n  max-width: 100%;\n  display: flex;\n  flex-direction: column;\n  gap: var(--gallery-space);\n  margin-bottom: var(--gallery-space);\n}\n\n.CRO-2763-active .testimonial-container {\n  position: relative;\n}\n\n.CRO-2763-active .gallery-wrapper .testimonial-container {\n  margin-bottom: var(--gallery-space);\n}\n\n.CRO-2763-active .gallery-wrapper > .gallery .picture {\n  width: 100%;\n  border-radius: 12px;\n  margin-bottom: 0;\n}\n\n.CRO-2763-active .work-section__item--gallery {\n  background-color: lightgray;\n}\n\n.yellow-work-1 .work-section__item--img {\n  object-position: bottom center;\n}\n\n.yellow-work-3 .work-section__item--img {\n  height: 107px;\n}\n\n.pink-work-3 .work-section__item--img {\n  width: 180px;\n}\n\n.purple-work-1 .work-section__item--img {\n  object-position: bottom center;\n}\n\n.red-work-3 .work-section__item--img {\n  width: 180px;\n  object-position: top center;\n}\n\n.white-work-1 .work-section__item--img {\n  object-position: bottom center;\n  height: 90px;\n}\n\n.white-work-3 .work-section__item--img {\n  object-position: top center;\n}\n\n.CRO-2763-active .gallery-wrapper .testimonial-container {\n  padding-top: 5px;\n}\n\n.CRO-2763-active .gallery-wrapper__guaranted {\n  margin-bottom: 0;\n  display: none !important;\n}\n\n.CRO-2763-active .product-wrapper__guaranted,\n.CRO-2763-active .attributes-guaranteed-delivery {\n  display: none !important;\n}\n\n.CRO-2763-active .product-essential {\n  margin-bottom: var(--space-between-sections);\n  display: flex;\n  gap: 61px;\n  justify-content: center;\n  padding: 0 10px;\n}\n\n.CRO-2763-active .product-essential .fcb-description {\n  display: none;\n}\n\n.CRO-2763-active .product-order-overview {\n  display: none;\n}\n\n.CRO-2763-active .overview-accordion-item .fcb-description {\n  padding-top: 0;\n}\n\n.CRO-2763-active .productTabs {\n  max-width: 100%;\n  width: 1040px;\n  margin: 0 auto;\n}\n\n.CRO-2763-active .recommendation-section {\n  max-width: 100%;\n  width: 1040px;\n  margin: 0 auto;\n}\n\n.CRO-2763-active .productTabs-body .fcb-description {\n  padding-top: 0;\n}\n\n@media (min-width: 981px) {\n  .CRO-2763-active .header-menu {\n    margin-top: var(--header-menu-mtop);\n    margin-bottom: var(--header-menu-mbottom);\n  }\n\n  .CRO-2763-active .header-menu > ul {\n    background-color: var(--header-menu-bg);\n  }\n\n  .CRO-2763-active .header-menu > ul > li > a {\n    font-weight: 400;\n  }\n\n  .CRO-2763-active .header-menu .separator-line {\n    height: var(--header-menu-line-size);\n  }\n}\n\n@media (max-width: 991px) {\n  .CRO-2763-active .obituary-banner__content {\n    flex-direction: column;\n    gap: 12px;\n  }\n\n  .CRO-2763-active .product-essential {\n    gap: 24px;\n  }\n\n  .CRO-2763-active .obituary-banner__content-detail {\n    width: 100%;\n    align-items: center;\n  }\n\n  .CRO-2763-active .obituary-banner__prefix {\n    font-size: 16px;\n  }\n}\n\n@media (max-width: 768px) {\n  .CRO-2763-active {\n    --space-between-sections: 19px;\n    --gallery-space: 0;\n  }\n\n  .mobile-hidden {\n    display: none !important;\n  }\n\n  .CRO-2763-active .ts-customizable-body {\n    padding-top: 24px;\n  }\n\n  .CRO-2763-active .product-essential {\n    flex-direction: column;\n    gap: 0;\n    padding: 0;\n  }\n\n  .gallery-wrapper {\n    margin-bottom: 24px;\n  }\n\n  .CRO-2763-active .gallery-wrapper .gallery {\n    width: 100%;\n  }\n\n  .CRO-2763-active .testimonial-container {\n    padding-left: 25px;\n    margin-top: var(--space-between-sections);\n  }\n\n  .CRO-2763-active .testimonial-message {\n    padding-top: 10px;\n  }\n\n  .CRO-2763-active .testimonial-message:before {\n    margin: 0;\n    top: -15px;\n    left: -20px;\n  }\n\n  .CRO-2763-active .attributes-delivery .attributes-list-obit-selected {\n    padding-bottom: 0;\n  }\n\n  .CRO-2763-active .attributes-delivery .attributes {\n    margin-bottom: 0;\n  }\n\n  .CRO-2763-active .work-section__item--gallery {\n    height: 107px;\n  }\n\n  .white-work-1 .work-section__item--img {\n    height: 100%;\n  }\n}\n\n@media (min-width: 769px) {\n  .desktop-hidden {\n    display: none !important;\n  }\n\n  .CRO-2763-active .gallery-wrapper {\n    width: 464px;\n  }\n\n  .CRO-2763-active .product-essential > .overview {\n    width: 464px;\n    padding: 0;\n  }\n\n  .CRO-2763-active .product-details-page .overview .attributes ul.option-list {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n  }\n\n  .CRO-2763-active .product-details-page .overview .attributes ul.option-list li {\n    width: 100%;\n  }\n}</style>", "dependencies": []}, {"id": "eb0da95c90d045f9ae40c2fa0614e034", "type": "widget", "dependencies": [], "name": "TS- How it Work", "widget_id": "6346387848167424", "config": {"selector": ".gallery-wrapper .gallery", "insertType": "beforeend", "customClass": "mobile-hidden"}}, {"id": "e089e1f499314f3a8b20ab1603dd793c", "type": "widget", "dependencies": [], "name": "TS - Header hamburger menu ", "widget_id": "6245909369978880", "config": {}}, {"id": "1c750b4dd323452e9564c6283282c4be", "type": "widget", "dependencies": [], "name": "TS- How it Work", "widget_id": "6346387848167424", "config": {"selector": ".product-wrapper__guaranted.desktop-hidden", "insertType": "beforebegin", "customClass": "desktop-hidden"}}]}]}], "weightDistributions": [{"ent