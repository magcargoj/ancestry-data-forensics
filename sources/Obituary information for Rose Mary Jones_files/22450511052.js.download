orebegin", "pageType": ""}}]}]}, {"id": "6405962056073216", "name": "Variation #2", "actions": [{"viewId": "24174540572", "changes": [{"id": "C89E92A5-928C-4589-976F-E49C0641B239", "type": "append", "selector": "head", "value": "<style>.ts-event-banner {\n  --event-banner-width: 1214px;\n}</style>", "dependencies": []}, {"id": "BE238D3A-B8C0-43CE-A152-668AA974C327", "type": "widget", "dependencies": [], "name": "TS - Event Banner", "widget_id": "5985368860786688", "config": {"customClass": "", "selector": ".clp-container", "insertType": "beforebegin", "pageType": "CLP"}}, {"id": "8B1FF324-D117-427A-8797-2E519CBC19F1", "type": "widget", "dependencies": [], "name": "TS - Event Modal", "widget_id": "4998598287425536", "config": {"customClass": "", "selector": ".ts-customizable-body-host", "insertType": "beforebegin", "pageType": "CLP"}}]}, {"viewId": "5953395954024448", "changes": [{"id": "1EDF5DAF-908F-402D-9CDC-9F92643AF42B", "type": "custom_code", "value": function($){const utils = window.optimizely.get("utils");

const attributeDeliveryElementSelector =
  ".delivery-section .attributes-delivery .attributes.ng-scope";

const deliveryDateInputSelector = "[data-fz-attribute-name='Delivery Date']";

const FUNERAL_HOME = "Funeral Home";
const FAMILY_ADDRESS = "Family Address";
const CUSTOM_ADDRESS = "Custom Address";

let updateFromModal = false;

function renderDeliverySection(element) {
  if (!element) return;

  const scope = window.angular.element(element).scope();
  const session = globalThis.ozlyDeliveryEvent.loadDataSession();
  const deliveryDateValueElement = element.querySelector(deliveryDateInputSelector);
  const deliveryDate = globalThis.ozlyDeliveryEvent.getSessionDeliveryDate();

  if (!session || !scope) return;

  const { itemType, Name, Start } = session;
  let locationType = Name;
  let date = "";
  const isFueranlHome = itemType === "location" && Name === FUNERAL_HOME;

  if (itemType === "event" || isFueranlHome) {
    date = Start;

    if (isFueranlHome && deliveryDate) {
      date = deliveryDate;
    }

    locationType = FUNERAL_HOME;
  } else {
    date = deliveryDate || "";
  }

  console.log("Render delivery section with session: ", locationType, " and date: ", date);

  if (date) {
    // Format date to mm/DD/YYYY
    formattedDate = globalThis.ozlyDeliveryEvent.convertFormatDatePicker(date);
    globalThis.DeliveryCalendarWasUpdated(formattedDate);

    // Update delivery date value in the delivery section
    deliveryDateValueElement.value = formattedDate;

    // Update Delivery Calendar
    $(".delivery-calendar.modal").find(".calendar").datepicker("setDate", formattedDate);
  }

  scope.$apply(() => {
    scope.locationTypeUpdate(locationType);
    if (Name === CUSTOM_ADDRESS) {
      scope.EditDeliveryLocation();
    }
  });
}

function getDefaultLocationTypeWhennoEvent() {
  const { IsNoEventDeliveryToFamilyByDefault } = globalThis.fz_model || {};
  if (IsNoEventDeliveryToFamilyByDefault) {
    return FAMILY_ADDRESS;
  }
  return null;
}

function applySelection(index) {
  if (index < 0) return;
  // const deliveryDate = $(deliveryDateInputSelector).val();
  globalThis.ozlyDeliveryEvent.saveSessionItem(index);
  globalThis.ozlyEventBanner.updateTitleBanner();
  globalThis.ozlyEventModal.updateUISelected(index);
}

function initDeliveryModelUpdate(element) {
  const scope = globalThis.angular.element(element).scope();
  if (!scope) return;

  function watchDeliveryDate(date) {
    const currentlyLocationType = $(".fz-locations-dropdown").val();
    globalThis.ozlyDeliveryEvent.saveSessionDeliveryDate(date);

    if (currentlyLocationType === FUNERAL_HOME) {
      const eventByDate = globalThis.ozlyDeliveryEvent.getEventByDeliveryDate(date);
      if (eventByDate) {
        applySelection(
          globalThis.ozlyDeliveryEvent
            .getItems()
            .findIndex((item) => item.Name === eventByDate.Name)
        );
      } else {
        // no event if IsNoEventDeliveryToFamilyByDefault is true, set Family address
        const defaultLocationType = getDefaultLocationTypeWhennoEvent() || currentlyLocationType;
        applySelection(
          globalThis.ozlyDeliveryEvent
            .getItems()
            .findIndex((item) => item.Name === defaultLocationType)
        );
      }
    } else {
      applySelection(
        globalThis.ozlyDeliveryEvent
          .getItems()
          .findIndex((item) => item.Name === currentlyLocationType)
      );
    }

    console.log(
      "DeliveryDate changed to: ",
      date,
      "current location type: ",
      currentlyLocationType
    );
  }

  scope.$watch("DeliveryDate", (newVal) => {
    if (updateFromModal) {
      updateFromModal = false;
      return;
    }
    setTimeout(() => {
      watchDeliveryDate(newVal);
    });
  });
}

function updateLocationType(type) {
  const items = globalThis.ozlyDeliveryEvent.getItems();
  if (!Array.isArray(items) || items.length === 0) return;

  if (type === FUNERAL_HOME) {
    const deliveryDate = $(deliveryDateInputSelector).val();
    const eventByDate = globalThis.ozlyDeliveryEvent.getEventByDeliveryDate(deliveryDate);
    if (eventByDate) {
      applySelection(items.findIndex((item) => item.Name === eventByDate.Name));
      return;
    }
  }

  applySelection(items.findIndex((item) => item.Name === type));
}

$(function () {
  utils.waitForElement(attributeDeliveryElementSelector).then((element) => {
    renderDeliverySection(element);
    initDeliveryModelUpdate(element);
  });

  document.addEventListener("ozlyEventModal:updated", () => {
    updateFromModal = true;
    renderDeliverySection(document.querySelector(attributeDeliveryElementSelector));
  });

  $(document).on(
    "click",
    ".delivery-location-information-editor .postal-code__field a",
    function (e) {
      e.preventDefault();
      updateLocationType($(".fz-locations-dropdown").val());
    }
  );
});
