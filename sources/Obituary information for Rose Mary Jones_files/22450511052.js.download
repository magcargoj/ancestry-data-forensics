        const utils = window.optimizely.get("utils");
const selectorExtension = `#optimizely-extension-${extension.$instance}`;

globalThis.ozlyEventBanner = {
  element: null,

  getEventSelectedTitle() {
    const session = globalThis.ozlyDeliveryEvent.loadDataSession();
    const { FormattedDate, Name } = session || {};
    return `Available for delivery to ${Name} ${FormattedDate || ""}`;
  },

  getTitleBanner() {
    console.log("Title Banner");
    const session = globalThis.ozlyDeliveryEvent.loadDataSession();
    const { Name, fhName } = session || {};
    
    const titleByLocation = {
      "Family Address": () => "Deliver to the family address on file",
      "Custom Address": () => "Deliver to a custom address (to be filled out in checkout)",
      "Funeral Home": () => `Deliver to ${fhName ? fhName : "funeral home"}`
    };

    return (titleByLocation[Name] || (() => this.getEventSelectedTitle()))();
  },

  getTemplateData() {
    return {
      extension,
      title: this.getTitleBanner()
    };
  },

  trackingEvent() {
    globalThis.ozly.getDataLayerValue("pageInfo.productsOffered");
    dataLayer.push({
      event: "ga4Event",
      "ga4.category": extension.pageType,
      "ga4.action": "Product Delivery - Open Modal",
      "ga4.label": this.getTitleBanner(),
      "ga4.purpose": "Navigation",
      "ga4.location": "Promo Banner"
    });
  },

  openEventModal() {
    if (globalThis.ozlyEventModal) {
      globalThis.ozlyEventModal.openModal();
    }
  },

  handleElementClick() {
    this.trackingEvent();
    this.openEventModal();
  },

  updateTitleBanner() {
    const titleElement = this.element.querySelector(".ts-event-banner__headline");
    if (titleElement) {
      titleElement.textContent = this.getTitleBanner();
    }
  },

  initListener() {
    // Add click event listener to the banner element
    this.element.addEventListener("click", () => {
      this.handleElementClick();
    });

    // Listen for update banner title event
    document.addEventListener("ozlyEventModal:updated", () => {
      this.updateTitleBanner();
    });

    // Clean up event listener on unload
    document.addEventListener(
      "beforeunload",
      () => {
        this.element.removeEventListener("click", () => {
          this.handleElementClick();
        });

        document.removeEventListener("ozlyEventModal:updated", () => {
          this.updateTitleBanner();
        });
      },
      { once: true }
    );
  },

  init(element) {
    this.element = element;
    // Init Event Banner JS here
    this.initListener();
  }
};

if (extension.selector) {
  utils.waitForElement(extension.selector).then((elem) => {
    const templateData = globalThis.ozlyEventBanner.getTemplateData();
    const html = extension.$render(templateData);
    elem.insertAdjacentHTML(extension.insertType, html);
  });

  utils.waitForElement(selectorExtension).then((elem) => {
    globalThis.ozlyEventBanner.init(elem);
  });
}

