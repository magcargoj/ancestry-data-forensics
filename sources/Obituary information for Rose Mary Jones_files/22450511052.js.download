e {\n  \t\tpadding-bottom: 10px;\n  }\n  \n  .memorial-contribution.memorial-contribution__mtg\n  .memorial-contributon__item--description {\n  \tmargin-bottom: 10px;\n    line-height: 20px;\n    font-size: 14px;\n  }\n}</style>", "dependencies": []}]}]}], "weightDistributions": [{"entityId": "28222310206", "endOfRange": 5000}, {"entityId": "28195460374", "endOfRange": 10000}], "name": "CRO-142 TCO | Obit | My Tribute Gift BHAG", "bucketingStrategy": null, "experimentMetadata": {"allocationPolicy": "manual", "layerId": "28168890369"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["28201270515"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": [{"id": "F002BE89-1D00-4894-BC20-8D93C830C5E4", "type": "custom_code", "value": function($){document.getElementsByTagName("html")[0].classList.add("CRO-2656-active");

const isMobileView = () => globalThis.innerWidth <= 1024;

const getHeightStickyHeader = (headerElement) => {
  const clone = headerElement.cloneNode(true);
  if (globalThis.isBuilderObituary) {
    clone.classList.add("fr-sticky-header-styles");
  } else {
    clone.classList.add("extended", "fixed", "site-header-clone");
  }
  Object.assign(clone.style, {
    visibility: "hidden",
    position: "absolute",
    top: "-9999px",
    left: "0",
    width: `${headerElement.offsetWidth}px`
  });
  document.body.appendChild(clone);
  const height = clone.offsetHeight;
  clone.remove();
  return height;
};

const calculateHeaderOffset = (space = 0) => {
  const headerSelector = globalThis.isBuilderObituary ? ".fr-header-wrapper" : ".site-header";
  const header = document.querySelector(headerSelector);
  if (!header) return 0;

  // get Header style set fixed or sticky
  const headerStyle = globalThis.getComputedStyle(header);
  const headerCssPosition = headerStyle.position;

  const isHeaderSticky =
    header.classList.contains("sticky-header") ||
    header.classList.contains("navbar-fixed-top") ||
    headerCssPosition === "fixed";

  const topNav = document.querySelector(".top-obit-nav");
  const topNavHeight = topNav ? topNav.offsetHeight + 20 : 0;

  if (!isHeaderSticky) {
    return topNavHeight + space;
  }

  const headerHeight = getHeightStickyHeader(header);
  return globalThis.isBuilderObituary ? headerHeight + space : headerHeight + topNavHeight + space;
};

globalThis.ozlyReadMoreComponent = {
  element: null,
  lastPrevScrollY: 0,

  init(element) {
    this.element = element;
    this.setupEventListeners(element);
  },

  tracking(text) {
    globalThis.dataLayer.push({
      event: "ga4Event",
      "ga4.category": "Obituary",
      "ga4.purpose": "Engagement",
      "ga4.location": "Obituary",
      "ga4.action": `Obituary - ${text}`,
      "ga4.label": text
    });
  },

  scrollToObituaryInfo() {
    const obituaryInfoSection = document.querySelector(".obituary-info");
    if (!obituaryInfoSection) return;

    const offsettop = calculateHeaderOffset(10);

    globalThis.materialObit.$scrollTo(".obituary-info", "1000", {
      easing: "ease-in",
      container: ".material-vue",
      force: true,
      lazy: true,
      cancelable: false,
      x: false,
      y: true,
      offset: -offsettop
    });
  },

  handleEventClickedReadMore(e) {
    const isHide = !this.element.classList.contains("active");
    this.tracking(isHide ? "Hide" : "Read More");

    if (!isMobileView() || !isHide) return;

    globalThis.requestAnimationFrame(() => this.scrollToObituaryInfo());
  },

  setupEventListeners() {
    // WHen read more link is clicked, scroll to top of obituary info section
    this.element.addEventListener("click", () => this.handleEventClickedReadMore());

    // Clean up event listener when the experiment is deactivated
    globalThis.addEventListener(
      "beforeunload",
      () => {
        this.element.removeEventListener("click", () => this.handleEventClickedReadMore());
      },
      { once: true }
    );
  }
};
