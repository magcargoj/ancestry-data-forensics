ributions": null, "decisionMetadata": null, "concluded": false}, {"changes": [{"id": "94dc0e6afb4b4c83b7c3244c75ec5999", "type": "custom_code", "value": function($){document.getElementsByTagName("html")[0].classList.add("CRO-2015-active");

window.clpUpdateCategoriesImage = (images) => {
  const categoriesItems = Array.from(document.querySelectorAll(".clp-category__item"));

  categoriesItems.forEach((item) => {
    const img = item.querySelector(".clp-category__item-thumb img");
    const categoriesThumbs = item.querySelector(".clp-category__item-thumb");

    // Get href to determine which image to use
    const url = `${window.location.origin}${item.getAttribute("href")}`;
    const categoryUrl = new URL(url);
    let pathName = categoryUrl.pathname.replace("/", ""); // e.g., "memorial-tree"
    // Check if pathName contains florist-choice-bouquet e.g., /ffn-florist-choice-bouquet" add this case
    if (pathName.includes("florist-choice-bouquet")) {
      pathName = "florist-choice-bouquet";
    }

    const categoryItem = images[pathName] || { srcSet: img.src, src: img.src };

    img.src = categoryItem.src;
    img.loading = "lazy";
    img.onload = () => {
      categoriesThumbs.classList.add("active");
    };
    const picture = document.createElement("picture");

    const source = document.createElement("source");
    source.setAttribute("media", "(max-width: 768px)");
    source.setAttribute("srcset", categoryItem.srcSet || categoryItem.src);
    picture.appendChild(source);

    picture.appendChild(img);

    categoriesThumbs.innerHTML = "";
    categoriesThumbs.appendChild(picture);
  });
};
