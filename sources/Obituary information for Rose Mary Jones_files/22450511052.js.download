3-A0C5-7B740E332F96", "type": "append", "selector": "head", "value": "<style>/* Past Event */\n.CRO-2365-active .no-events .is-past-message {\n  order: 1;\n}\n\n.CRO-2365-active .no-events .event-item.is-past-message {\n  --event-past-item-padding: 18px 20px;\n}\n\n.CRO-2365-active .obituary-events .no-events .is-past-message .event-past-description {\n  visibility: hidden;\n}\n\n.CRO-2365-active .obituary-events .no-events .is-past-message .event-past-description.ready {\n  visibility: visible;\n}\n\n.CRO-2365-active .no-events .event-past-title {\n  font-family: \"Source Serif Pro\", serif;\n}\n\n.CRO-2365-active .event-past-button {\n  font-size: 15px;\n  font-family: \"Source Sans Pro\", sans-serif;\n}\n\n.hide {\n  display: none !important;\n}\n\n@media (max-width: 768px) {\n  .CRO-2365-active .no-events .event-item.is-past-message {\n    --event-past-item-padding: 16px 20px;\n  }\n}</style>", "dependencies": []}, {"id": "E5A8B57F-A5C4-4AA4-B343-B4A47135F0B1", "type": "custom_code", "value": function($){document.getElementsByTagName("html")[0].classList.add("CRO-2365-active");

const PRODUCT_OFFERINGS = globalThis.ozly.getDataLayerValue("pageInfo.productsOffered") || "";

const DATE_EVENT_OBTUARY = window.ozly.getDataLayerValue("eventInfo.timeUntilLast");

const productOfferrings = {
  tree: PRODUCT_OFFERINGS.includes("Trees"),
  flower: PRODUCT_OFFERINGS.includes("Flowers")
};

// Regex pattern matches a minus sign followed by one or more digits (e.g., '-3')
const PAST_EVENT_PATTERN = /-\d+/;

const getCustomPastEventDescription = () => {
  const { tree, flower } = productOfferrings;
  const firstName = globalThis.MaterialData.user.firstName;
  const baseMessage = "Even if there are no events, you can still show support";

  if (tree && flower) {
    return `${baseMessage} by sending flowers or planting a tree in memory.`;
  }

  if (tree) {
    return `${baseMessage} by planting a tree in memory of ${firstName}.`;
  }

  if (flower) {
    return `${baseMessage} by sending flowers.`;
  }

  return "Even if there are no events.";
};

globalThis.ozlyCRO2365 = {
  productOfferrings,
  updatePastEventDescription(element) {
    element.textContent = getCustomPastEventDescription();
    element.classList.add("ready");
  },
  isEventInPast() {
    return PAST_EVENT_PATTERN.test(DATE_EVENT_OBTUARY);
  },
  isNoEvent() {
    return window.ozly.getDataLayerValue("abTestInfo.obitEvents") === "0";
  }
};
}, "dependencies": []}], "id": "5772445160833024", "name": "(DRAFT) CRO-2365 TCO | Obit | Non-Event Obit | Add Banner to Event section if Family Address is on File", "commitId": "5271269277433856", "groupId": null, "holdback": 0, "activation": {}, "integrationSettings": {"google_analytics_4": {"is_using_gtm": "on"}}, "integrationStringVersion": 2, "experiments": [{"audienceIds": ["and", "23582011142", "27769750132", "4835162433781760", "27724250398", "4652099238100992", "4972801866596352", "5921046222602240"], "audienceName": "Prod QA,ProductsOffered Contains Trees or Flowers,Not run in Private Event,Frazer/SRS template,Obits with no events,Enabled No Event Text,Enabled Store Sentence in Bio", "changes": null, "id": "5515898736345088", "integrationSettings": null, "variations": [{"id": "6078848689766400", "name": "Original", "actions": [{"viewId": "23529631800", "changes": []}]}, {"id": "5659433565421568", "name": "Variation #1", "actions": [{"viewId": "23529631800", "changes": [{"id": "64EB9FEB-DD78-4C83-8972-2C2983E3271B", "type": "custom_code", "value": function($){const utils = globalThis.optimizely.get("utils");

utils.waitForElement(".obituary-events .no-events").then((element) => {
  element.classList.add("event-list", "events-grid", "events-grid__lg");
});

utils
  .waitForElement(".obituary-events .no-events .event-item.is-past-message .event-past-description")
  .then((element) => {
    globalThis.ozlyCRO2365.updatePastEventDescription(element);
  });

utils
  .waitForElement(".obituary-events .event-list:not(.no-events) .event-item.is-past-message")
  .then((element) => {
    if (!globalThis.ozlyCRO2365.isNoEvent()) {
      element.classList.add("hide");
    }
  });
}, "dependencies": []}, {"id": "22EE1EFD-24EB-4491-86D8-191A10B1A577", "type": "append", "selector": "head", "value": "<style>.CRO-2365-active .no-events .event-item.is-past-message {\n  --event-past-item-padding: 18px 20px;\n}\n\n.CRO-2365-active .obituary-events .no-events > span {\n  display: none;\n}\n\n.CRO-2365-active .no-events .event-past-wrapper {\n  gap: 16px;\n}</style>", "dependencies": []}, {"id": "43444419-0144-42ED-ABC7-8C2B28A77A93", "type": "widget", "dependencies": [], "name": "TCO - Past Event Item", "widget_id": "4722313376038912", "config": {"selector": ".obituary-events .no-events", "insertType": "beforeend", "title": "", "customClass": "", "isTrackNiEvent": "0"}}, {"id": "BAE5FE4C-3BED-4A23-8D25-02607EAD50E4", "type": "widget", "dependencies": [], "name": "TCO - No Event Item", "widget_id": "6262151963213824", "config": {"selector": ".obituary-events .no-events", "insertType": "beforeend", "customClass": "", "description": "There are currently no events scheduled. \n<br>Please check back later for updates."}}, {"id": "33DBCED0-9CA3-47E6-A6BF-49F0038DCB0F", "type": "widget", "dependencies": [], "name": "TCO - Past Event Item", "widget_id": "4722313376038912", "config": {"selector": ".obituary-events .event-list:not(.no-events)", "insertType": "beforeend", "title": "", "customClass": "full-width", "isTrackNiEvent": "0"}}]}]}, {"id": "5454949367152640", "name": "Variation #2", "actions": [{"viewId": "23529631800", "changes": [{"id": "E807E0F3-F48A-4175-92D0-730357F9B46B", "type": "custom_code", "value": function($){const utils = globalThis.optimizely.get("utils");

