        const utils = globalThis.optimizely.get("utils");

const DEFAULT_CTA_LABEL = "Get event updates";

const PRODUCT_OFFERINGS = window.ozly.getDataLayerValue("pageInfo.productsOffered") || "";

const productOfferrings = {
  tree: PRODUCT_OFFERINGS.includes("Trees"),
  flower: PRODUCT_OFFERINGS.includes("Flowers")
};

function classHandler() {
  const { tree, flower } = productOfferrings;
  if (tree && flower) {
    return "no-event-item--tree-flower";
  } else if (tree) {
    return "no-event-item--tree-only";
  } else if (flower) {
    return "no-event-item--flower-only";
  } else {
    return "";
  }
}

function getTemplateData() {
  return {
    extension,
    cta_label: DEFAULT_CTA_LABEL,
    isTree: productOfferrings.tree,
    isFlower: productOfferrings.flower,
    description: extension.description,
    containerClass: classHandler()
  };
}

function pushToDataLayer(payload) {
  if (!globalThis.dataLayer || typeof globalThis.dataLayer.push !== "function") return;
  globalThis.dataLayer.push(payload);
}

function trackCtaClick(label) {
  pushToDataLayer({
    event: "ga4Event",
    "ga4.category": "Obituary",
    "ga4.purpose": "Event",
    "ga4.location": "Event List",
    "ga4.action": "Event Update CTA",
    "ga4.label": label
  });
}

function trackCardView() {
  pushToDataLayer({
    event: "niEvent",
    "ga4.category": "Obituary",
    "ga4.purpose": "Event",
    "ga4.location": "Event List",
    "ga4.action": "niEvent - Scheduled Events",
    "ga4.label": "View Get Event Updates"
  });
}

function bindCtaClick(instanceId, label) {
  utils
    .waitForElement(`#optimizely-extension-${instanceId} .no-event-card__cta`)
    .then((ctaButton) => {
      ctaButton.addEventListener("click", () => {
        trackCtaClick(label);
        globalThis.materialObit.$store.commit("CHANGE_GET_UPDATES_MODAL", true);
      });
    });
}

function observeCardView(instanceId) {
  utils.waitForElement(`#optimizely-extension-${instanceId}`).then((element) => {
    let hasTracked = false;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!hasTracked && entry.isIntersecting) {
          hasTracked = true;
          trackCardView();
          observer.unobserve(element);
        }
      });
    });

    observer.observe(element);

    const handleBeforeUnload = () => {
      observer.disconnect();
      globalThis.removeEventListener("beforeunload", handleBeforeUnload);
    };

    globalThis.addEventListener("beforeunload", handleBeforeUnload);
  });
}

// Render the extension
if (extension.selector) {
  utils.waitForElement(extension.selector).then((elem) => {
    const templateData = getTemplateData();
    const html = extension.$render(templateData);
    elem.insertAdjacentHTML(extension.insertType, html);

    bindCtaClick(extension.$instance, DEFAULT_CTA_LABEL);
    observeCardView(extension.$instance);
  });
}

