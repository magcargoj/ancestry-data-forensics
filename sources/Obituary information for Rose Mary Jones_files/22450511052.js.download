const trackClickMemorialDonate = (text, place) => {
  dataLayer.push({
    event: "ga4Event",
    "ga4.category": "Obituary",
    "ga4.purpose": "Ecommerce",
    "ga4.location": place,
    "ga4.action": "Donation Click - CRO-1738 - V1",
    "ga4.label": `${text} - V1`
  });
};

const isFlowerTreeEnabled = () => {
  return (
    window.MaterialData.pageSettings.IsForObituaryStoreActive &&
    window.MaterialData.pageSettings.ShowTreeStore
  );
};

const isNoStore = () => {
  return (
    !window.MaterialData.pageSettings.IsForObituaryStoreActive &&
    !window.MaterialData.pageSettings.ShowTreeStore
  );
};

const calculateTopBannerOffset = ({ targetEle, titleEle }) => {
  const titleHeight = titleEle ? titleEle.getBoundingClientRect().height : 0;
  const sectionTop = targetEle ? parseInt(window.getComputedStyle(targetEle).paddingTop, 10) : 0;

  const navHeaderSelector = window.isBuilderObituary ? ".fr-header-wrapper" : ".site-header";
  const navHeader = document.querySelector(navHeaderSelector);
  let navSize = 0;
  if (navHeader) {
    navSize = 25;
    if (window.getComputedStyle(navHeader, null).getPropertyValue("position") === "fixed") {
      navSize = navHeader.getBoundingClientRect().height;
      if (window.isBuilderObituary && navSize > 0) {
        navSize -= 75;
      }
    }
  }
  const offset = titleHeight + navSize + sectionTop;
  return offset > 0 ? -offset : 0;
};

/**
 * Function to navigate to the donation section of the page.
 * This function will scroll the page to the donation section.
 */
const actionDonationClicked = () => {
  if (!document.querySelector(".donation-contribution")) {
    return;
  }

  const options = {
    easing: "ease-in",
    container: ".material-vue",
    offset: calculateTopBannerOffset({
      targetEle: document.querySelector(".donation-contribution"),
      titleEle: document.querySelector(".donation-contribution__title")
    }),
    force: true,
    lazy: true,
    cancelable: false,
    x: false,
    y: true
  };
  window.materialObit.$scrollTo(".donation-contribution", 1000, options);
};

/**
 *  * Creates a donation button element and attaches an onclick event to navigate to the donation section.
 * @param {Function} fnCallback
 * @returns html button element
 */
const getDonationButton = (fnCallback) => {
  const donationButton = document.createElement("button");
  const btnCls = ["memorial-donation-button", "btn", "btn-material"];
  btnCls.forEach((cls) => donationButton.classList.add(cls));

  donationButton.onclick = function (e) {
    e.preventDefault();

    if (typeof fnCallback === "function") {
      fnCallback(e);
    }
    actionDonationClicked();
  };

  donationButton.textContent = "Memorial Donation";
  return donationButton;
};

const getTextLinkObituaryDonation = () => {
  const span = document.createElement("span");
  span.classList.add("obituary-description__donate");
  span.textContent = `To make a memorial donation, `;

  const anchor = document.createElement("a");
  anchor.classList.add("obituary-description__donate--link");
  anchor.textContent = "please visit the donations section";
  anchor.onclick = function (e) {
    e.preventDefault();
    trackClickMemorialDonate(e.target.textContent, "Events List");
    actionDonationClicked();
  };

  span.appendChild(anchor);
  span.insertAdjacentHTML("beforeend", " of this obituary.");
  return span;
};

utils.waitForElement(".donation-contribution").then((element) => {
  window.pushViewMemorialContributeNievent1738(element, "V1");
  const links = Array.from(document.querySelectorAll(".donate-contribution-item__link"));

  const niEventSeeUI = () => {
    dataLayer.push({
      event: "niEvent",
      "ga4.category": "Obituary",
      "ga4.purpose": "Ecommerce",
      "ga4.location": "Obit Menu",
      "ga4.action": "niEvent - View Donation CTA- CRO-1738 - V1",
      "ga4.label": "View CTA - V1"
    });
  };

  const trackClickDonateBtn = (event) => {
    dataLayer.push({
      event: "ga4Event",
      "ga4.category": "Obituary",
      "ga4.purpose": "Ecommerce",
      "ga4.location": "Events List",
      "ga4.action": "Donate Now Button Click - CRO-1738 - V1",
      "ga4.label": `${event.target.innerText} - V1`
    });
  };

  niEventSeeUI();

  links.forEach((link) => {
    const clonelink = link.cloneNode(true);
    clonelink.onclick = trackClickDonateBtn;
    link.insertAdjacentElement("afterend", clonelink);
    link.remove();
  });

  utils.waitForElement(".obituary-info .obituary-description").then((element) => {
    const template = getTextLinkObituaryDonation();
    if (isNoStore()) {
      element.insertAdjacentElement("beforeend", template);
    } else {
      element
        .querySelector(".obituary-description__store")
        .insertAdjacentElement("beforeend", template);
    }
  });

  utils.waitForElement(".obituary-info .obituary-noDescription > span").then((element) => {
    const template = getTextLinkObituaryDonation();
    if (isNoStore()) {
      template.insertAdjacentHTML("afterbegin", "<br>");
    }
    element.insertAdjacentElement("beforeend", template);
  });
});

jQuery(function () {
  jQuery(document).on("ajaxComplete", function (event, xhr, settings) {
    if (settings.url.includes("GetObituaryMemorialContributionAsync")) {
      jQuery("#primary-mobile-nav").addClass("visbile");
    }
  });
});

const ctoWatchContributeTitle = utils.observeSelector(
  ".donate-contribution-item__title",
  (element) => {
    element.innerText = element.innerText.replace("Donate to", "Memorial Donations to");
  }
);

window.addEventListener("beforeunload", (event) => {
  if (ctoWatchContributeTitle && typeof ctoWatchContributeTitle === "function") {
    ctoWatchContributeTitle();
  }
});
}, "dependencies": []}, {"id": "0634845E-D1B0-48DE-9D22-CC42DE7F064A", "type": "append", "selector": "head", "value": "<style>.btn-material.memorial-donation-button {\n  border-radius: 49px;\n  background: #188b50;\n  display: flex;\n  padding: 13px 29px;\n  justify-content: center;\n  align-items: center;\n  text-align: center;\n  font-style: normal;\n  font-weight: 600;\n  font-size: 16px;\n  line-height: 24px;\n  height: 50px;\n}\n\n.btn-material.memorial-donation-button:hover {\n  background-color: #167d48;\n  color: #fff;\n  outline: none;\n}\n\n.btn-material.memorial-donation-button:focus {\n  background: #188b50;\n  color: #fff;\n  outline: none;\n}\n\n.top-obit-nav__btn-share {\n  order: 2;\n}\n\n.top-obit-nav__btns-front .memorial-donation-button {\n  order: 1;\n  margin-left: 5px;\n}\n\n.CRO-1738-active .top-obit-nav__btns-front .top-obit-nav__btn.orange {\n  margin-right: 5px;\n}\n\n.CRO-1738-active .top-obit-nav__btn {\n  padding: 13px 16px;\n  height: 50px;\n  align-items: center;\n}\n\n.CRO-1738-active .three-buttons .top-obit-nav__btn {\n  padding: 13px 16px;\n  width: clamp(130px, 7.552vw, 145px);\n  justify-content: center;\n  display: flex;\n}\n\n.CRO-1738-active .three-buttons .top-obit-nav__btn.top-obit-nav__btn-share {\n  width: 100px;\n}\n\n.three-buttons .top-obit-menu__buttons .top-obit-nav__menu-item {\n  padding: 10px 14px;\n}\n\n.CRO-1738-active\n  #obituaryInfo\n  .obituary-description__donate\n  a.obituary-description__donate--link {\n  color: #188b50;\n  text-decoration: underline;\n}\n\n.CRO-1738-active\n  #obituaryInfo\n  .obituary-description__donate\n  a.obituary-description__donate--link:hover {\n  color: #444;\n  text-decoration: none;\n}\n\n.CRO-1738-active .donate-contribution-item__link {\n  font-size: 16px;\n}\n\n.obituary-description__store .obituary-description__donate {\n  padding-left: 3px;\n}\n\n.CRO-1738-active #primary-mobile-nav {\n  visibility: hidden;\n}\n\n.CRO-1738-active #primary-mobile-nav.visbile {\n  visibility: visible;\n}\n\n@media (max-width: 1199px) {\n  .three-buttons #primary-mobile-nav {\n    row-gap: 17px;\n    column-gap: 21px;\n  }\n\n  #primary-mobile-nav {\n    gap: 16px;\n    padding: 12px 6px;\n  }\n\n  #primary-mobile-nav .mobile-nav__flex-item {\n    padding: 0;\n    flex-grow: 1;\n    flex-shrink: unset;\n    flex-basis: calc(50% - 16px);\n  }\n\n  .CRO-1738-active #primary-mobile-nav .top-obit-nav__btn {\n    margin: 0;\n  }\n\n  #primary-mobile-nav .mobile-nav__flex-item .memorial-donation-button {\n    width: 100%;\n    height: 50px;\n  }\n}</style>", "dependencies": []}]}]}], "weightDistributions": [{"entityId": "4668536379932672", "endOfRange": 5000}, {"entityId": "5850324817149952", "endOfRange": 10000}], "name": "CRO-1738 TCO | Altmeyer | Obit | Donation Testing", "bucketingStrategy": null, "experimentMetadata": {"allocationPolicy": "manual", "layerId": "6600461524926464"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["5614878778458112"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": [{"id": "694DC54C-7677-4B5C-855D-606AB32CCF04", "type": "custom_code", "value": function($){document.getElementsByTagName("html")[0].classList.add("CRO-1935-active");

const SESSION_INDEX = `ozlyEventSelected-${globalThis.ozly.getDataLayerValue("pageInfo.tcoObitId")}`;

const SESSION_DELIVERY_DATE_KEY = `ozly-delivery-date-${globalThis.ozly.getDataLayerValue("pageInfo.tcoObitId")}`;

const SESSION_TIMEOUT = 3600000; // 1 hour

const locale_type = "en-US";

globalThis.ozlyDeliveryEvent = {
  //selectedItem: null,

  addOrdinalSuffix(day) {
    const lastTwoDigits = day % 100;
    if (lastTwoDigits >= 11 && lastTwoDigits <= 13) return "th";
    return { 1: "st", 2: "nd", 3: "rd" }[lastTwoDigits % 10] || "th";
  },

  normalizeToMidnight(dateInput) {
    const date = new Date(dateInput);
    date.setHours(0, 0, 0, 0);
    return date;
  },

  isEventToday(eventDate) {
    const date = this.normalizeToMidnight(eventDate);
    const today = this.normalizeToMidnight(new Date());
    return date.getTime() === today.getTime();
  },

  // if tomorrow
  isEventTomorrowDate(eventDate) {
    const date = this.normalizeToMidnight(eventDate);
    const tomorrow = this.normalizeToMidnight(new Date());
    tomorrow.setDate(tomorrow.getDate() + 1);
    return date.getTime() === tomorrow.getTime();
  },

  isEventBeyondTomorrow(eventDate) {
    const date = this.normalizeToMidnight(eventDate);
    const dayAfterTomorrow = this.normalizeToMidnight(new Date());
    dayAfterTomorrow.setDate(dayAfterTomorrow.getDate() + 2);
    return date.getTime() >= dayAfterTomorrow.getTime();
  },

  formatDateEvent(eventDate) {
    const date = new Date(eventDate);
    if (Number.isNaN(date.getTime())) return "";

    const isToday = this.isEventToday(date);
    const isTomorrow = this.isEventTomorrowDate(date);
    let prefix = "";
    if (isToday) {
      prefix = "today";
    } else if (isTomorrow) {
      prefix = "tomorrow,";
    } else if (this.isEventBeyondTomorrow(date)) {
      prefix = date.toLocaleDateString(locale_type, { weekday: "short" });
    }

    const formattedMonth = date.toLocaleDateString(locale_type, { month: "short" });
    const dayWithSuffix = `${date.getDate()}${this.addOrdinalSuffix(date.getDate())}`;
    const formattedTime = date.toLocaleTimeString(locale_type, {
      hour: "numeric",
      minute: "numeric"
    });

    return `${prefix ? `${prefix} ` : ""}${formattedMonth} ${dayWithSuffix} at ${formattedTime}`;
  },

  formatAddress(addressLocation) {
    if (!addressLocation) return [];

    const { Address1, Address2, City, State, PostalCode } = addressLocation;
    const addressLines = [Address1, Address2].filter(Boolean).map((line) => line.trim());

    const cityState = [City, State]
      .filter(Boolean)
      .map((part) => part.trim())
      .join(", ");

    const cityStateZip = [cityState, PostalCode]
      .filter(Boolean)
      .map((part) => part.trim())
      .join(cityState ? " " : "");

    if (cityStateZip) addressLines.push(cityStateZip);

    return addressLines;
  },

  normalizeLocationType(locationTypes) {
    if (!locationTypes) return [];

    let parsed = locationTypes;

    try {
      parsed = typeof locationTypes === "string" ? JSON.parse(locationTypes) : locationTypes;
    } catch (e) {
      return [];
    }

    if (!Array.isArray(parsed)) return [];

    const { ActiveEvents } = globalThis.fz_model;
    const events = this.normalizeEvent(ActiveEvents);

    const descriptionByName = {
      "Family Address": "It’s on file but not shared publicly, out of respect for the family.",
      "Custom Address": "Enter address details in checkout"
    };

    return parsed
      .filter(({ IsEnabled }) => IsEnabled)
      .map((loc) => {
        loc.description = descriptionByName[loc.Name] || "";
        loc.itemType = "location";
        loc.isNextEvent = false;

        if (loc.Name === "Funeral Home") {
          // Get first event date for funeral home location
          const eventForFuneralHome = events.find(
            (event) => event.itemType === "event" && event.isNextEvent
          );
          if (eventForFuneralHome) {
            // loc.fhName = eventForFuneralHome.Name ? eventForFuneralHome.Name : "";
            loc.fhName = "funeral home";
            // loc.FormattedDate = eventForFuneralHome.FormattedDate;
            loc.Start = eventForFuneralHome.Start;
            loc.addressLines = eventForFuneralHome.addressLines;
          }
        }
        return loc;
      });
  },

  normalizeEvent(events) {
    if (!events) return [];
    // Sort events by date ascending
    let newEvents = events.sort((a, b) => new Date(a.Start) - new Date(b.Start));

    const { FirstDelivery } = globalThis.fz_model; // {id: eventId that match first delivery, e.g. 12345}
    if (FirstDelivery) {
      // If event match first delivery date, move it to first
      const indexFirstDelivery = newEvents.findIndex((event) => event.Id === FirstDelivery.Id);
      if (indexFirstDelivery > 0) {
        const [firstDeliveryEvent] = newEvents.splice(indexFirstDelivery, 1);
        newEvents.unshift(firstDeliveryEvent);
      }
    }

    newEvents = newEvents.map((event, index) => {
      //event.Name = event.Location.Name ? event.Location.Name.trim() : "";
      event.Name = event.EventName;
      event.LocationName = event.Location.Name ? event.Location.Name.trim() : "";
      event.FormattedDate = this.formatDateEvent(event.Start);
      event.LocationType = event.Location.LocationType;
      event.addressLines = this.formatAddress(event.Location);
      event.itemType = "event";
      event.isNextEvent = index === 0;
      return event;
    });

    return newEvents;
  },

  getItems() {
    const { ActiveEvents, LocationTypes } = globalThis.fz_model;
    const events = this.normalizeEvent(ActiveEvents);
    const locationTypes = this.normalizeLocationType(LocationTypes);
    const session = this.loadDataSession();

    const items = [];
    events.forEach((event) => {
      event.isSelected = session && session.itemType === "event" && session.Id === event.Id;
      items.push(event);
    });

    locationTypes.forEach((loc) => {
      loc.isSelected = session && session.itemType === "location" && session.Name === loc.Name;
      items.push(loc);
    });

    return items;
  },

  getItemByIndex(index) {
    const items = this.getItems();
    return items[index];
  },

  saveSessionItem(index, { deliveryDate } = {}) {
    console.log("Saving session item with index:", index);
    const item = this.getItemByIndex(index);
    if (!item) return;

    globalThis.localStorage.setItem(
      SESSION_INDEX,
      JSON.stringify({
        item: item,
        expriedIn: Date.now() + SESSION_TIMEOUT // 1 hour
      })
    );
  },

  saveSessionDeliveryDate(deliveryDate) {
    globalThis.localStorage.setItem(
      SESSION_DELIVERY_DATE_KEY,
      JSON.stringify({
        deliveryDate,
        expriedIn: Date.now() + SESSION_TIMEOUT // 1 hour
      })
    );
  },

  getSessionDeliveryDate() {
    const sessionData = globalThis.localStorage.getItem(SESSION_DELIVERY_DATE_KEY);
    if (!sessionData) return null;
    try {
      const { deliveryDate, expriedIn } = JSON.parse(sessionData);
      if (Date.now() > expriedIn) {
        this.removeSessionDeliveryDate();
        return null;
      }
      return deliveryDate;
    } catch (e) {
      return null;
    }
  },

  getSessionItem() {
    const sessionData = globalThis.localStorage.getItem(SESSION_INDEX);
    if (!sessionData) return null;
    try {
      const { item, expriedIn } = JSON.parse(sessionData);
      if (Date.now() > expriedIn) {
        this.removeSessionItem();
        return null;
      }
      return item;
    } catch (e) {
      return null;
    }
  },

  removeSessionItem() {
    globalThis.localStorage.removeItem(SESSION_INDEX);
  },

  removeSessionDeliveryDate() {
    globalThis.localStorage.removeItem(SESSION_DELIVERY_DATE_KEY);
  },

  loadDataSession() {
    const { LocationTypes, ActiveEvents } = globalThis.fz_model;
    const sessionItem = this.getSessionItem();
    if (!sessionItem) {
      // Find preselected item
      const locationTypes = this.normalizeLocationType(LocationTypes);
      const preselectedLocation = locationTypes.find((loc) => loc.IsPreselected);

      const events = this.normalizeEvent(ActiveEvents);
      const preselectedEvent = events ? events[0] : null;

      if (preselectedLocation && preselectedLocation.Name !== "Funeral Home") {
        return preselectedLocation;
      } else if (preselectedEvent) {
        return preselectedEvent;
      } else {
        return null;
      }
    }
    return sessionItem;
  },

  convertFormatDatePicker(date) {
    const dateCls = new Date(date);
    return `${String(dateCls.getMonth() + 1).padStart(2, "0")}/${String(dateCls.getDate()).padStart(2, "0")}/${dateCls.getFullYear()}`;
  },

  getFuneralHome() {
    const { FuneralHomeAddress } = globalThis.fz_model || {};
    return FuneralHomeAddress;
  },

  parseDate(value) {
    if (!value) return null;

    if (value instanceof Date) {
      return Number.isNaN(value.getTime()) ? null : value;
    }

    if (typeof value === "number") {
      const numericDate = new Date(value);
      return Number.isNaN(numericDate.getTime()) ? null : numericDate;
    }

    if (typeof value === "string") {
      const [month, day, year] = value.split("/").map((part) => part && part.trim());
      if (month && day && year) {
        const formatted = new Date(`${year}-${month}-${day}`);
        return Number.isNaN(formatted.getTime()) ? null : formatted;
      }
    }

    return null;
  },

  getEventByDeliveryDate(eventDate) {
    const targetDateRaw = this.parseDate(eventDate);
    if (!targetDateRaw) return undefined;

    const targetDate = this.normalizeToMidnight(targetDateRaw);

    return this.getItems().find((item) => {
      if (item.itemType !== "event" || !item.Start) return false;
      const itemDate = this.normalizeToMidnight(new Date(item.Start));
      return itemDate.getTime() === targetDate.getTime();
    });
  }
};
