let stringToObject=function(e,r){r=r.replace(/\[(\w+)\]/g,".$1");r=r.replace(/^\./,"");for(var t=r.split("."),a=0,n=t.length;a<n;++a){var o=t[a];if(e!==Object(e)||!(o in e))return;e=e[o];}return e;};
