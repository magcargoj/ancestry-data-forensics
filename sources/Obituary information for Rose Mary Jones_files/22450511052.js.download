widget._styleTag.innerHTML = ':root {  --event-modal-display: none;  --event-modal-overlay-bg-color: rgba(0, 0, 0, 0.4);  --event-modal-container-padding: 24px;  --event-modal-container-width: 999px;  --event-modal-border-radius: 0px;  --event-modal-titles-gap: 16px;  --event-modal-title-font-size: 24px;  --event-modal-title-font-weight: 600;  --event-modal-title-margin: 0;  --event-modal-subtitle-font-size: 16px;  --event-modal-subtitle-font-weight: 400;  --event-modal-subtitle-margin: 0;  /*--event-modal-list-grid-template-columns: repeat(3, minmax(300px, 1fr));*/  --event-modal-list-gap: 24px;  --event-item-border-color: transparent;  --event-item-border-color-selected: #c6dfe0;  --event-item-opacity: 0;  --event-item-opacity-selected: 1;  --event-item-z-index: -1;  --event-item-z-index-selected: 0;  --event-button-color: #1a8082;}.success-mode {  --event-modal-titles-gap: 13px;  --event-modal-container-width: 302px;  --event-modal-border-radius: 4px;}.event-modal {  display: var(--event-modal-display);  background-color: transparent;  position: relative;  top: 0;  right: 0;  bottom: 0;  left: 0;  z-index: 9998;  -webkit-overflow-scrolling: touch;  text-align: center;  outline: 0;}.event-modal.is-open {  --event-modal-display: flex;}.event-modal__wrapper {  background-color: var(--event-modal-overlay-bg-color);  position: fixed;  top: 0;  left: 0;  display: flex;  align-items: center;  justify-content: center;  width: 100%;  height: 100%;  z-index: 9998;}.event-modal__container {  padding: var(--event-modal-container-padding);  width: var(--event-modal-container-width) !important;  max-width: calc(100vw - 15px);  max-height: calc(100vh - 15px);  overflow-y: auto;  margin: 0;  transition: all 0.3s ease;  background-color: #fff;  position: relative;  border-radius: var(--event-modal-border-radius);}.event-modal__btn-close {  position: absolute;  top: 0;  right: 0;  display: flex;  width: 36px;  height: 36px;  padding: 8px;  justify-content: center;  align-items: center;  cursor: pointer;}.event-modal__content {  height: auto;}.event-list-page {  display: flex;  flex-direction: column;  gap: 24px;}.event-modal.success-mode .event-list-page {  display: none;}.event-modal__titles {  display: flex;  flex-direction: column;  gap: var(--event-modal-titles-gap);  color: #444;  font-family: "Source Sans Pro", sans-serif;  text-align: center;  align-items: center;}.event-modal__title {  font-size: var(--event-modal-title-font-size) !important;  font-weight: var(--event-modal-title-font-weight);  margin: var(--event-modal-title-margin) !important;}.event-modal__subtitle {  font-size: var(--event-modal-subtitle-font-size) !important;  font-weight: var(--event-modal-subtitle-font-weight) !important;  margin: var(--event-modal-subtitle-margin) !important;}.event-modal__events-list {  display: flex;  flex-wrap: wrap;  justify-content: center;  gap: var(--event-modal-list-gap);}.event-modal__event-item {  display: flex;  flex-direction: column;  gap: 12px;  border-radius: 4px;  background: #fff;  box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.25);  justify-content: center;  position: relative;  padding-bottom: 12px;  width: calc(100% / 3 - var(--event-modal-list-gap));}.event-modal__event-item:before {  content: " ";  width: 100%;  height: 100%;  position: absolute;  top: 0;  left: 0;  background: transparent;  border-radius: 4px;  z-index: var(--event-item-z-index);  border: 2px solid var(--event-item-border-color);  opacity: var(--event-item-opacity);  transition: all 0.3s;}.event-modal__event-item.selected:before,.event-modal__event-item:hover:before {  border: 2px solid var(--event-item-border-color-selected);  opacity: var(--event-item-opacity-selected);  z-index: var(--event-item-z-index-selected);}.event-item__titles {  display: flex;  padding: 16px 0;  min-height: 80px;  gap: 8px;  flex-direction: column;  align-items: center;  justify-content: center;  background: #e8f2f3;  font-family: "Source Serif Pro", serif;  color: #333;}.event-item__title {  font-size: 16px;  font-style: normal;  font-weight: 400;  line-height: 20px;}.event-item__date {  font-size: 12px;  font-style: normal;  font-weight: 400;  line-height: normal;  text-transform: capitalize;}.event-item__content {  flex-grow: 1;  color: #333;  text-align: center;  font-family: var(--Font-Lato);  font-size: 12px;  font-style: normal;  font-weight: 400;  line-height: 16px;  display: flex;  flex-direction: column;  min-height: 32px;  padding: 0 16px;  justify-content: center;}.event-item__cta {  z-index: 1;  display: flex;  justify-content: center;  padding: 0 16px;}.event-item__select-button {  max-width: 100%;  width: 208px;  padding: 8px 12px;  display: flex;  justify-content: center;  align-items: center;  gap: 4px;  border-radius: 44px;  border: 1px solid #a3cccd;  background: #fff;  box-shadow: 0 1px 2px 0 rgba(16, 24, 40, 0.05);  color: var(--event-button-color);  font-family: var(--Font-Lato);  font-size: 14px;  font-style: normal;  font-weight: 400;  line-height: 20px;  transition: all 0.3s;  outline: none;}.event-item__select-button .text-selected,.event-item__select-button .event-item__select-button-icon {  display: none;}.event-item__select-button .text-select {  display: flex;}.event-modal__event-item.selected .event-item__select-button {  background-color: var(--event-button-color);  border-color: var(--event-button-color);  color: #fff;}.event-modal__event-item.selected .event-item__select-button .text-select {  display: none;}.event-modal__event-item.selected .event-item__select-button .text-selected,.event-modal__event-item.selected .event-item__select-button .event-item__select-button-icon {  display: flex;}.event-item__next-pill {  display: flex;  padding: 2px 8px;  align-items: center;  border-radius: 16px;  border: 1px solid #c6dfe0;  background: #f4f9f9;  font-size: 12px;  font-style: normal;  font-weight: 500;  line-height: 18px;  color: #333;  text-align: center;  font-family: var(--Font-Lato);}.success-page {  display: none;  justify-content: center;  align-items: center;  gap: 13px;}.event-modal.success-mode .success-page {  display: flex;  flex-direction: column;}.event-modal__success-message {  min-height: 79px;  display: flex;  flex-direction: column;  gap: 4px;  justify-content: center;  color: #333;  font-style: normal;  font-weight: 400;  line-height: normal;}.success-message__name {  font-family: "Source Serif Pro", serif;  font-size: 16px;  line-height: 20px;}.success-message__date {  font-size: 12px;  font-family: var(--Font-Lato);}@media (hover: hover) {  .event-item__select-button:hover {    border-color: #a3cccd;    background: #f4f9f9;    color: #104d4e;    outline: none;  }  .event-modal__event-item.selected .event-item__select-button:hover {    background-color: #146062;    border-color: #146062;    color: #fff;  }}@media (max-width: 768px) {  :root {    --event-modal-container-padding: 38px 33px;  }  .event-modal__event-item {    width: min(100%, 300px);  }}@media (max-width: 480px) {  .event-modal__event-item {    width: 100%;  }}';
document.getElementsByTagName('head')[0].appendChild(widget._styleTag);
        const utils = window.optimizely.get("utils");
const selectorExtension = `#optimizely-extension-${extension.$instance}`;

const TIME_OUT_SHOW_SUCCESS = 1500;

globalThis.ozlyEventModal = {
  element: null,
  CLS_MODAL_OPEN: "is-open",

  CLS_SELECTED: "selected",

  SUCCESS_MODE: "success-mode",

  getTemplateData() {
    return {
      extension,
      items: globalThis.ozlyDeliveryEvent.getItems()
    };
  },

  openModal() {
    if (!this.element) return;
    this.element.classList.add(this.CLS_MODAL_OPEN);
  },

  closeModal() {
    if (!this.element) return;
    this.element.classList.remove(this.CLS_MODAL_OPEN);
    this.element.classList.remove(this.SUCCESS_MODE);
  },

  getEventItemsElement() {
    if (!this.element) return [];
    return Array.from(this.element.querySelectorAll(".event-modal__event-item"));
  },

  clearSelected() {
    this.getEventItemsElement().forEach((item) => item.classList.remove(this.CLS_SELECTED));
  },

  setSuccessMessage() {
    const session = globalThis.ozlyDeliveryEvent.loadDataSession();
    const successMessageElement = this.element.querySelector(".event-modal__success-message");

    if (!successMessageElement || !session) return;

    const createMessageBlock = (className, text) => {
      const block = document.createElement("div");
      block.classList.add(className);
      block.textContent = text;
      return block;
    };

    const { Name, itemType, FormattedDate, fhName } = session;
    let deliveryDate = globalThis.ozlyDeliveryEvent.getSessionDeliveryDate();
    if (deliveryDate) {
      deliveryDate = globalThis.ozlyDeliveryEvent.formatDateEvent(deliveryDate);
    }

    // Clear and prepare success message element
    successMessageElement.innerHTML = "";
    successMessageElement.classList.remove("hide");

    // Determine name and date to display
    let displayName = Name || "";
    let displayDate = deliveryDate || FormattedDate;

    // Special handling for Funeral Home location type
    if (itemType === "location" && Name === "Funeral Home") {
      displayName = fhName || "";
    }

    // Append message blocks
    if (displayName) {
      successMessageElement.appendChild(createMessageBlock("success-message__name", displayName));
    }

    if (displayDate) {
      successMessageElement.appendChild(createMessageBlock("success-message__date", displayDate));
    }
  },

  handleSelectItem(index) {
    const items = this.getEventItemsElement();
    const item = items[index];
    if (!item) return;

    if (!item.classList.contains(this.CLS_SELECTED)) {
      this.updateUISelected(index);
    }

    this.closeModal();

    this.element.classList.add(this.SUCCESS_MODE);

    globalThis.ozlyDeliveryEvent.saveSessionItem(index);

    const selectedItem = globalThis.ozlyDeliveryEvent.getItemByIndex(index);
    if (selectedItem && selectedItem.Start) {
      globalThis.ozlyDeliveryEvent.saveSessionDeliveryDate(selectedItem.Start);
    }

    globalThis.requestAnimationFrame(() => {
      this.setSuccessMessage();

      this.openModal();

      raiseCustomEvent("ozlyEventModal:updated", globalThis.ozlyDeliveryEvent.loadDataSession());

      setTimeout(() => {
        this.closeModal();
      }, TIME_OUT_SHOW_SUCCESS);
    });
  },

  updateUISelected(index) {
    const items = this.getEventItemsElement();
    const item = items[index];

    if (!item) return;
    this.clearSelected();

    globalThis.requestAnimationFrame(() => {
      item.classList.add(this.CLS_SELECTED);
    });
  },

  initEvent() {
    this.element.addEventListener("click", (e) => {
      // Close the modal when clicking outside the modal container
      if (e.target.classList.contains("event-modal__wrapper")) {
        this.closeModal();
      }
    });

    const closeButton = this.element.querySelector(".event-modal__btn-close");
    closeButton.addEventListener("click", (e) => {
      this.closeModal();
    });

    const itemButtons = Array.from(this.element.querySelectorAll(".event-item__select-button"));

    itemButtons.forEach((button, index) => {
      button.addEventListener("click", (e) => {
        this.handleSelectItem(index);
      });
    });

    // clear event click listeners on unload
    document.addEventListener(
      "beforeunload",
      () => {
        itemButtons.forEach((button, index) => {
          button.removeEventListener("click", (e) => {
            this.handleSelectItem(index);
          });
        });
      },
      { once: true }
    );
  },

  init(element) {
    this.element = element;
    this.initEvent();
  }
};

if (extension.selector) {
  utils.waitForElement(extension.selector).then((elem) => {
    const templateData = globalThis.ozlyEventModal.getTemplateData();
    const html = extension.$render(templateData);
    elem.insertAdjacentHTML(extension.insertType, html);
  });

  utils.waitForElement(selectorExtension).then((elem) => {
    globalThis.ozlyEventModal.init(elem);
  });
}

      },
      hideFn: function(event) {
        var $ = window.optimizely.get('jquery');
        var widget = event.data.config;
        widget.$id = "4998598287425536";
        widget.$instance = event.data.id;
        widget.$fieldDefaults = [{"name":"customClass","default_value":""},{"name":"selector","default_value":".ts-customizable-body-host"},{"name":"insertType","default_value":"beforebegin"},{"name":"pageType","default_value":""}];
        (function(widg) {
  var i = 0;
  var field;
  for (; i < widg.$fieldDefaults.length; ++i) {
    field = widg.$fieldDefaults[i];
    if (!widg.hasOwnProperty(field.name)) {
      widg[field.name] = field.default_value;
    }
  }
  })(widget);
        var extension = widget;
        widget._styleTag = document.getElementById('widget-css-4998598287425536');
if (widget._styleTag) widget._styleTag.parentNode.removeChild(widget._styleTag);
        /*
 * Editor now supports ES6 compliant code. Note that adding ES6
 * specific code to an experiment will break for users running
 * ES5-only browsers as code entered is not transpiled down to ES5.
 */
 
  const extensionElement = document.getElementById('optimizely-extension-' + extension.$instance);
  if (extensionElement) {
    extensionElement.parentElement.removeChild(extensionElement);
  }

      },
