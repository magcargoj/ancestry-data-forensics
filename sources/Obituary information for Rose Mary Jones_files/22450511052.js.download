O-2322-active .event-past-buttons.event-past-buttons--two .event-past-button {\n  --epast-btn-width: 100%;\n}\n\n@media (max-width: 768px) {\n  .event-past-buttons.event-past-buttons--two {\n    --past-button-size: 1fr;\n  }\n\n  .event-past-buttons--two .event-past-buttons__tree.event-past-button,\n  .event-past-buttons--two .event-past-buttons__flower.event-past-button {\n    --epast-btn-width: 152px;\n  }\n}</style>", "dependencies": []}, {"id": "C2363B6F-91C6-48C1-BC72-CF76D6426787", "type": "widget", "dependencies": [], "name": "TCO - Past Event Item", "widget_id": "4722313376038912", "config": {"selector": ".obituary-events .event-list", "insertType": "beforeend", "title": "Ways to offer support", "customClass": "full-width"}}]}]}, {"id": "6284234873110528", "name": "Variation #3", "actions": [{"viewId": "23529631800", "changes": [{"id": "0DA8A4EC-1C09-49AC-81C5-9DCB6ACAD1CA", "type": "append", "selector": "head", "value": "<style>.CRO-2322-active .event-item.is-past-message {\n  align-items: flex-start;\n  gap: 14px;\n  order: 1;\n}\n\n.CRO-2322-active .event-past-wrapper {\n  align-items: flex-start;\n  text-align: left;\n  flex-wrap: wrap;\n  flex-direction: row;\n}\n\n.CRO-2322-active .event-past-icon {\n  margin-right: 2px;\n}\n\n@media (max-width: 768px) {\n  .CRO-2322-active .event-item.is-past-message {\n    gap: 16px;\n  }\n\n  .CRO-2322-active .event-past-wrapper {\n    gap: 16px;\n  }\n\n  .CRO-2322-active .event-item.is-past-message:has(.event-past-buttons--two) .event-past-wrapper {\n    text-align: center;\n  }\n\n  .CRO-2322-active .event-past-icon {\n    margin-right: 0px;\n  }\n\n  .event-past-buttons.event-past-buttons--two {\n    margin: auto;\n  }\n}</style>", "dependencies": []}, {"id": "625B1067-A05C-4C97-A16E-80E3CFD62746", "type": "widget", "dependencies": [], "name": "TCO - Past Event Item", "widget_id": "4722313376038912", "config": {"selector": ".obituary-events .event-list", "insertType": "beforeend", "title": "Ways to offer support", "customClass": "full-width"}}]}]}], "weightDistributions": [{"entityId": "6748476948611072", "endOfRange": 2500}, {"entityId": "5325998141472768", "endOfRange": 5000}, {"entityId": "5716321044791296", "endOfRange": 7500}, {"entityId": "6284234873110528", "endOfRange": 10000}], "name": "(DRAFT) CRO-2322 TCO | Obit | No future events | Add Banner to Event section if Family Address is on File", "bucketingStrategy": null, "experimentMetadata": {"allocationPolicy": "manual", "layerId": "5260993241022464"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["23529631800"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": [{"id": "34C5647A-D90A-421D-A796-CD6EA6B6FF93", "type": "append", "selector": "head", "value": "<style>.CRO-2403-active {\n  --Font-Sspro: \"Source Serif Pro\", serif;\n  --header-menu-bg: transparent;\n  --header-menu-mtop: 24px;\n  --header-menu-mbottom: 16px;\n  --header-menu-line-size: 0;\n  --obitbanner-gap: 48px;\n}\n\n.ts-custom-header .logo a:focus {\n  outline: none;\n}\n\n.obituary-banner__title {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n  align-items: center;\n  z-index: 2;\n}\n\n.obituary-banner__title--main {\n  /* min 20 max 48*/\n  font-size: clamp(20px, 2.5vw, 48px);\n  font-family: var(--Font-Sspro);\n  font-style: normal;\n  font-weight: 700;\n  line-height: 48px; /* 100% */\n  letter-spacing: 3px;\n  color: #333;\n  text-align: center;\n  margin: 0;\n}\n\n.obituary-banner__title--sub {\n  color: var(--Dark-Grey);\n  font-family: var(--Font-Lato);\n  font-size: clamp(15px, 1.042vw, 20px);\n  font-style: normal;\n  font-weight: 400;\n  line-height: 24px; /* 120% */\n  letter-spacing: 0.4px;\n}\n\n.CRO-2403-active .attributes-list--guaranteed {\n  background: rgba(203, 218, 252, 0.5);\n  display: flex;\n  padding: 16px;\n  justify-content: center;\n  align-items: center;\n}\n\n.CRO-2403-active .attributes-list--guaranteed .guaranteed-message {\n  gap: 0;\n  text-align: center;\n}\n\n.CRO-2403-active .attributes-list--guaranteed .guaranteed-message__title {\n  font-size: 14px;\n  line-height: 20px;\n  letter-spacing: normal;\n}\n\n.CRO-2403-active .attributes-list--guaranteed .guaranteed-message__text {\n  font-size: 14px;\n}\n\n@media (max-width: 991px) {\n  .CRO-2403-active {\n    --obitbanner-gap: 12px;\n  }\n\n  .obituary-banner__title {\n    gap: 8px;\n  }\n\n  .obituary-banner__title--main {\n    letter-spacing: 0.6px;\n    line-height: 28px;\n  }\n\n  .obituary-banner__title--sub {\n    letter-spacing: 0.3px;\n  }\n}</style>", "dependencies": []}, {"id": "82D19C3E-D7DD-4A5E-A7BE-419C0AC299D4", "type": "custom_code", "value": function($){document.getElementsByTagName("html")[0].classList.add("CRO-2403-active");

window.ozlyDCcomponents = (() => {
  const utils = window.optimizely.get("utils");

  function titleBannerTemplate() {
    const div = document.createElement("div");
    div.classList.add("obituary-banner__title");
    const template = `
            <h1 class="obituary-banner__title--main">Send a one-of-a-kind arrangement</h1>
            <div class="obituary-banner__title--sub">
                Made with the freshest flowers by a local florist
            </div>
        `;
    div.insertAdjacentHTML("beforeend", template);
    return div;
  }

  function addTitleBanner() {
    utils.waitForElement(`.obituary-banner__content`).then((element) => {
      const titleBanner = titleBannerTemplate();
      element.insertAdjacentHTML("beforebegin", titleBanner.outerHTML);
    });
  }

  function changePositionHeaderMenu() {
    utils.waitForElement(`.ts-custom-header`).then((element) => {
      utils.waitForElement(`.ts-customizable-body > .header-menu`).then((headerMenu) => {
        element.insertAdjacentElement("afterend", headerMenu);
      });
    });
  }

  function removeBreadcrumb() {
    // Remove Product breadcrumb
    utils.waitForElement(`.product.breadcrumb`).then((element) => {
      element.remove();
    });
  }

  function moveProductDescription() {
    // For Desktop Move Product Description to tab section
    utils.waitForElement(`.productTabs #tabs-1`).then((tab) => {
      utils.waitForElement(`.fcb-description.mobile-hidden`).then((element) => {
        element.classList.remove("mobile-hidden");
        tab.insertAdjacentElement("afterbegin", element);
      });
    });

    // For Mobile Move Product Description below Accordion
    utils.waitForElement(`.overview-accordion-item .accordion-body__detail`).then((accordian) => {
      utils.waitForElement(`.gallery-wrapper .fcb-description.desktop-hidden`).then((element) => {
        element.classList.remove("desktop-hidden");
        accordian.insertAdjacentElement("afterend", element);
      });
    });
  }

  function addTestimonial(targetSelector) {
    utils.waitForElement(`.gallery-wrapper .testimonial-container`).then((element) => {
      // Clone Testimonial Section
      const cloneTestimonial = element.cloneNode(true);

      // hide original testimonial from mobile
      element.classList.add("mobile-hidden");

      cloneTestimonial.classList.add("desktop-hidden");
      utils.waitForElement(targetSelector).then((targetElement) => {
        targetElement.insertAdjacentElement("afterend", cloneTestimonial);
      });
    });
  }

  function guaranteedDeliveryTemplate() {
    const div = document.createElement("div");
    div.classList.add("attributes-list--guaranteed");
    const template = `
      <div class="guaranteed-message">
        <div class="guaranteed-message__title">Guaranteed Hand Delivery</div>
        <div class="guaranteed-message__text">By a local florist chosen by the funeral home</div>
      </div>
    `;
    div.insertAdjacentHTML("beforeend", template);
    return div;
  }

  function createAttributeGuaranteedDelivery() {
    utils
      .waitForElement(".options-group__attribute.attributes-delivery .attributes")
      .then((element) => {
        const guaranteedDelivery = guaranteedDeliveryTemplate();
        element.insertAdjacentElement("beforeend", guaranteedDelivery);
      });
  }

  return {
    addTitleBanner,
    titleBannerTemplate,
    changePositionHeaderMenu,
    removeBreadcrumb,
    moveProductDescription,
    addTestimonial,
