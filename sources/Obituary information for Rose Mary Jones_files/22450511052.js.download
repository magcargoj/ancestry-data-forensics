    srcSet: "https://d1uep5tseb3xou.cloudfront.net/content/images/feature/sprays2x-min.webp"
  },
  {
    src: "https://d1uep5tseb3xou.cloudfront.net/content/images/feature/flower-backet.webp",
    srcSet: "https://d1uep5tseb3xou.cloudfront.net/content/images/feature/flower-backet-min.webp"
  },
  {
    src: "https://d1uep5tseb3xou.cloudfront.net/content/images/feature/designers_choice2x.webp",
    srcSet:
      "https://d1uep5tseb3xou.cloudfront.net/content/images/feature/designers_choice2x-min.webp"
  }
];

utils
  .waitUntil(
    () =>
      Array.from(document.querySelectorAll(".clp-category__list .clp-category__item")).length > 0
  )
  .then(() => {
    window.clpRenderCategories();
    window.clpUpdateCategoriesImage(categoriesImages);
  });

utils.waitForElement(".shop-badget").then((element) => {
  window.updateTreeBadgetBanner(element, "CLP");
});

utils.waitForElement(".clp-bottom-container").then(window.clpUpdateBottomContainer);
}, "dependencies": []}, {"id": "f6b32d777bf04eb793ec448fed605d48", "type": "append", "selector": "head", "value": "<style>.CRO-2015-active .obituary-info-widget,\n.CRO-2015-active .h-wrapper {\n  display: none !important;\n}\n.clp-page .ts-customizable-body {\n  margin-top: 0;\n}\n\n.CRO-2015-active .ts-custom-header .content {\n  display: flex;\n  align-items: center;\n  padding: 0;\n}\n\n.CRO-2015-active .ts-custom-header .logo a {\n  padding: 0 !important;\n}\n\n.CRO-2015-clp-variant .shop-badget__content-detail-block {\n  gap: 27px;\n}\n\n.CRO-2015-clp-variant .shop-badget__title {\n  font-size: 24px;\n}\n\n.CRO-2015-clp-variant .shop-badget__content-avatar {\n  height: 324px;\n}\n\n.CRO-2015-clp-variant a.btn-shop-now {\n  border-radius: 8px;\n  border: 1px solid #1a8082;\n  background: #1a8082;\n  color: #fff;\n}\n\n.CRO-2015-clp-variant a.btn-shop-now:hover,\n.CRO-2015-clp-variant a.btn-shop-now:focus {\n  color: #fff;\n  background-color: #104d4e;\n  border-color: #104d4e;\n}\n\n@media only screen and (max-width: 768px) {\n  .CRO-2015-clp-variant .shop-badget__content-avatar {\n    height: 262px;\n  }\n\n  .CRO-2015-clp-variant .shop-badget__content-detail-block {\n    gap: 27px;\n  }\n\n  .CRO-2015-clp-variant .shop-badget__content-detail {\n    padding: 16px;\n  }\n}\n\n@media only screen and (min-width: 980px) {\n  .CRO-2015-active div.ts-custom-header {\n    height: 200px;\n    display: flex;\n  }\n}\n\n@media (min-width: 768px) and (max-width: 1200px) {\n  .CRO-2015-clp-variant .shop-badget__content-detail-block {\n    gap: 27px;\n  }\n}</style>", "dependencies": []}, {"id": "2944696072b04f48a4cf151653621b66", "type": "widget", "dependencies": [], "name": "TS Shop badget", "widget_id": "5700721744543744", "config": {"selector": ".clp-container", "insertType": "beforeend", "bannerMobile": "https://d1uep5tseb3xou.cloudfront.net/content/images/feature/single-tree-min.webp", "bannerDesktop": "https://d1uep5tseb3xou.cloudfront.net/content/images/feature/single-tree-banner.webp", "href": "#limitPrice"}}]}, {"viewId": "23548420025", "changes": [{"id": "66e642283fa94172bdf2f922a17f0c4f", "type": "append", "selector": "head", "value": "<style>.CRO-2015-active .obituary-info-widget,\n.CRO-2015-active .h-wrapper {\n  display: none !important;\n}\n\n.CRO-2015-active .ts-customizable-body {\n  margin-top: 0;\n  padding-top: 20px;\n}\n\n.CRO-2015-active .ts-custom-header .content {\n  display: flex;\n  align-items: center;\n  padding: 0;\n}\n\n@media only screen and (min-width: 980px) {\n  .CRO-2015-active div.ts-custom-header {\n    height: 200px;\n    display: flex;\n    align-items: center;\n    padding: 10px;\n  }\n}\n\n@media (max-width: 981px) {\n  .CRO-2015-active .breadcrumb li * {\n    vertical-align: top;\n  }\n  .CRO-2015-active .ts-customizable-body {\n    padding-top: 0;\n  }\n}</style>", "dependencies": []}]}, {"viewId": "24926810405", "changes": [{"id": "e4c3585b2b8b444c89d2bc917857c54d", "type": "append", "selector": "head", "value": "<style>.CRO-2015-active .obituary-info-widget,\n.CRO-2015-active .h-wrapper {\n  display: none !important;\n}\n\n.CRO-2015-active .obituary-banner {\n  padding-bottom: 9px;\n}\n\n.CRO-2015-active .ts-customizable-body {\n  margin-top: 0;\n}\n\n.CRO-2015-active .ts-custom-header .content {\n  display: flex;\n  align-items: center;\n  padding: 0;\n}\n\n.CRO-2015-active .ts-custom-header .logo a {\n  padding: 0 !important;\n}\n\n@media only screen and (max-width: 980px) {\n  .CRO-2015-active .funeral-home-name {\n    display: flex;\n    justify-content: center;\n  }\n\n  .CRO-2015-active .ts-custom-header .content {\n    display: none;\n  }\n}\n\n@media only screen and (min-width: 980px) {\n  .CRO-2015-active div.ts-custom-header {\n    height: 200px;\n    padding: 0 16px;\n    display: flex;\n  }\n}\n\n@media (max-width: 1024px) {\n  .CRO-2015-active .ts-custom-header .content {\n    padding: 0 16px;\n  }\n\n  .CRO-2015-active .obituary-banner {\n    padding-top: 33px;\n    padding-bottom: 33px;\n  }\n}</style>", "dependencies": []}]}, {"viewId": "23470791003", "changes": [{"id": "ebc6a09b981f4e25ab3940d8c9110761", "type": "custom_code", "value": function($){const utils = window.optimizely.get("utils");

document
  .getElementsByTagName("html")[0]
  .classList.add("CRO-2015-plp-variant", "CRO-2015-plp-variant-1");

const isPLPMobileVersion = () => window.innerWidth < 981;
const getShopBadgetPosition = () => (isPLPMobileVersion() ? 4 : 8);

const isShowShopBadgetBanner = () => {
  const productItemsCount = Array.from(document.querySelectorAll(".item-box")).length;
  const threshold = getShopBadgetPosition();
  return productItemsCount > threshold;
};

const removeCloneShopBadgetBanner = () => {
  const existClone = document.querySelector(".shop-badget-clone");
  if (existClone) {
    existClone.remove();
  }
};

const generateShopBadgetBanner = () => {
  const shopBadgetBanner = document.querySelector(".shop-badget");
  removeCloneShopBadgetBanner();

  if (!shopBadgetBanner || !isShowShopBadgetBanner()) return;
  const cloneShopBadgetBanner = shopBadgetBanner.cloneNode(true);
  cloneShopBadgetBanner.classList.add("active");
  cloneShopBadgetBanner.classList.add("shop-badget-clone");
  document
    .querySelectorAll(".item-box")
    [getShopBadgetPosition()].insertAdjacentElement("beforebegin", cloneShopBadgetBanner);
};

// Delivery Banner, Sort and Filter (mobile)
utils.waitForElement(".master-wrapper-content").then((element) => {
  const deliveryBanner = window.plpDeliveryBannerComponent();
  element.insertAdjacentElement("afterbegin", deliveryBanner);

  utils.waitForElement(".delivery-banner-section__filters").then((deliveryFilter) => {
    // Sort button
    const sortData = window.plpGetSortOptions();
    if (sortData.length > 0) {
      const sortButton = window.plpSortButtonComponent();
      deliveryFilter.insertAdjacentElement("afterbegin", sortButton);
    }
  });
});

const obServeProductItems = utils.observeSelector(
  ".product-grid .item-box .product-item",
  function (item) {
    const category = item.getAttribute("data-category") || "";
    if (category.includes("tree")) {
      const badge = treeBadgeComponent();
      item.insertAdjacentHTML("afterbegin", badge);
    }
  }
);

utils.waitForElement(".shop-badget").then((element) => {
  window.updateTreeBadgetBanner(element);
});

utils
  .waitUntil(function () {
    return isShowShopBadgetBanner();
  })
  .then(function () {
    generateShopBadgetBanner();
  });

document.addEventListener("ajaxFilterComplete", function (e) {
  utils.waitForElement(".product-grid .item-box").then(() => {
    generateShopBadgetBanner();
  });
});

$(function () {
  utils.waitForElement(".delivery-banner-section__title-value").then((element) => {
    const cto = setTimeout(() => {
      const originalText = document.querySelector(".delivery-banner .delivery-time-text");
      if (element && originalText) {
        element.innerText = originalText.textContent;
      }
      element.parentElement.classList.add("ready");
      clearTimeout(cto);
    }, 400);
  });

  let previousScreen = window.innerWidth;
  $(window).on("resize", function () {
    const currentScreen = window.innerWidth;
    if (previousScreen !== currentScreen) {
      generateShopBadgetBanner();
    }
    previousScreen = currentScreen;
  });

  $(document).on("click", ".btn-shop-now--tree", function (e) {
    window.trackingTreeBadgetBanner("PLP");
  });
});

window.addEventListener("beforeunload", () => {
  if (obServeProductItems && typeof obServeProductItems === "function") {
    obServeProductItems();
  }
});
}, "dependencies": []}, {"id": "c5b06278753f4354b42915a4ecb435a2", "type": "append", "selector": "head", "value": "<style>.CRO-2015-active .obituary-info-widget,\n.CRO-2015-active .live-help-block,\n.CRO-2015-active .center-2 .delivery-banner,\n.CRO-2015-active .center-2 .category-description-wrapper,\n.CRO-2015-active .master-wrapper-main .breadcrumb.category,\n.CRO-2015-active .responsive-nav-wrapper-parent .responsive-nav-wrapper,\n.CRO-2015-active .h-wrapper {\n  display: none !important;\n}\n\n.btn-light {\n  border-radius: 8px;\n  border: 1px solid #d0d5dd;\n  background: #fff;\n  box-shadow: 0px 1px 2px 0px rgba(16, 24, 40, 0.05);\n  display: flex;\n  transition: background-color 0.5s;\n  color: #344054;\n  font-family: \"Lato\", sans-serif;\n  font-size: 16px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 20px;\n  outline: none !important;\n}\n\n.btn-light:hover,\n.btn-light:focus,\n.btn-light:active {\n  background-color: #f8f9fa;\n  color: #667085;\n  outline: none;\n  box-shadow: 0px 1px 2px 0px rgba(16, 24, 40, 0.05);\n}\n\n.CRO-2015-active .shop-badget {\n  display: none;\n  visibility: hidden;\n  transition: visibility 0.5s;\n}\n\n.CRO-2015-active .shop-badget.active {\n  display: flex;\n  visibility: visible;\n}\n\n.CRO-2015-active .shop-badget__content-detail-block {\n  gap: 27px;\n}\n\n.CRO-2015-active .shop-badget__title {\n  font-size: 24px;\n}\n\n.CRO-2015-active .shop-badget__content-avatar {\n  height: 262px;\n}\n\n.CRO-2015-active a.btn-shop-now {\n  border-radius: 8px;\n  border: 1px solid #1a8082;\n  background: #1a8082;\n  color: #fff;\n}\n\n.CRO-2015-active a.btn-shop-now:hover,\n.CRO-2015-active a.btn-shop-now:focus {\n  color: #fff;\n  background-color: #104d4e;\n  border-color: #104d4e;\n}\n\n@media only screen and (max-width: 980px) {\n  .CRO-2015-active .shop-badget__content-detail-block {\n    gap: 27px;\n    width: 100%;\n  }\n\n  .CRO-2015-active .shop-badget__content-detail {\n    padding: 24px 16px;\n  }\n}</style>"