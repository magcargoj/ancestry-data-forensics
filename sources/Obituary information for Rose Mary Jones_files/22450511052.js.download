}, "dependencies": []}, {"id": "862157FA-6618-4759-B81C-236D68C572EE", "type": "append", "selector": "head", "value": "<style>:root.CRO-2365-active {\n  --no-event-titles-direction: row;\n  --no-event-text-align: left;\n  --no-event-align-items: flex-start;\n}\n\n.CRO-2365-active .obituary-events .no-events > span {\n  display: none;\n}\n\n.CRO-2365-active .no-events .no-event-card__titles {\n  width: 100%;\n}\n\n.CRO-2365-active .no-event-card__title {\n  padding-top: 3px;\n  padding-bottom: 0;\n}\n\n/* Past Event */\n.CRO-2365-active .no-events .event-past-wrapper {\n  gap: 16px;\n}\n\n.CRO-2365-active .event-item.is-past-message {\n  align-items: flex-start;\n  gap: 16px;\n}\n\n.CRO-2365-active .event-past-wrapper {\n  align-items: flex-start;\n  text-align: left;\n  flex-wrap: wrap;\n  flex-direction: row;\n  flex-grow: 1;\n}\n\n.CRO-2365-active .event-past-buttons {\n  width: 100%;\n  justify-content: flex-start;\n}\n\n.CRO-2365-active .event-past-buttons.event-past-buttons--two {\n  justify-content: center;\n}\n\n@media (max-width: 1024px) {\n  .CRO-2365-active .no-event-card__title {\n    padding-top: 3px;\n    padding-bottom: 0;\n  }\n\n  .CRO-2365-active .event-item.is-past-message {\n    gap: 16px;\n  }\n\n  .CRO-2365-active .event-past-buttons--two .event-past-buttons__flower.event-past-button,\n  .CRO-2365-active .event-past-buttons--two .event-past-buttons__tree.event-past-button {\n    --epast-btn-width: 1fr;\n  }\n}</style>", "dependencies": []}, {"id": "2A64B3C6-80CC-4AE1-90F4-74EB99562769", "type": "widget", "dependencies": [], "name": "TCO - No Event Item", "widget_id": "6262151963213824", "config": {"selector": ".obituary-events .no-events", "insertType": "beforeend", "customClass": ""}}, {"id": "3E9A28BA-91E4-495E-A163-CF74F46DAA27", "type": "widget", "dependencies": [], "name": "TCO - Past Event Item", "widget_id": "4722313376038912", "config": {"selector": ".obituary-events .no-events", "insertType": "beforeend", "title": "Ways to offer support", "customClass": "", "isTrackNiEvent": "0"}}, {"id": "41FDA051-2B53-4046-8977-A18CBB05FBC0", "type": "widget", "dependencies": [], "name": "TCO - Past Event Item", "widget_id": "4722313376038912", "config": {"selector": ".obituary-events .event-list:not(.no-events)", "insertType": "beforeend", "title": "Ways to offer support", "customClass": "full-width", "isTrackNiEvent": "0"}}]}]}], "weightDistributions": [{"entityId": "6078848689766400", "endOfRange": 2500}, {"entityId": "5659433565421568", "endOfRange": 5000}, {"entityId": "5454949367152640", "endOfRange": 7500}, {"entityId": "4916631076339712", "endOfRange": 10000}], "name": "(DRAFT) CRO-2365 TCO | Obit | Non-Event Obit | Add Banner to Event section if Family Address is on File", "bucketingStrategy": null, "experimentMetadata": {"allocationPolicy": "manual", "layerId": "5772445160833024"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["23529631800"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": [{"id": "BD0A9303-7DF5-49A9-8DE5-C0A820056988", "type": "append", "selector": "head", "value": "<style>.CRO-2533-active {\n  --Font-Lato: \"Lato\", sans-serif;\n  --material-font-family: \"Source Sans Pro\", sans-serif;\n  --Base-White: #fff;\n  --fz-button-bg: var(--Base-White);\n  --fz-button-fcolor: #444;\n  --fz-button-radius: 44px;\n  --fz-button-height: 48px;\n  --fz-button-bcolor: var(--fz-button-fcolor);\n  --share-icon-hover-color: #d2d2d2;\n  --tippy-bg-color: #333;\n  --tippy-font-color: var(--Base-White);\n  --tippy-font-size: 12px;\n  --tippy-border-radius: 8px;\n  --tippy-font-family: \"Lato\", sans-serif;\n  --modal-mask-bg: rgba(0, 0, 0, 0.4);\n  --modal-title-fcolor: #101828;\n  --input-border-color: #ddd;\n  --error-color: #f00;\n  --show-desktop: flex;\n}\n\n.fz-button {\n  font-family: var(--material-font-family);\n  border-radius: var(--fz-button-radius);\n  border: 1px solid var(--fz-button-bcolor);\n  background: var(--fz-button-bg);\n  display: flex;\n  padding: 12px 24px;\n  justify-content: center;\n  align-items: center;\n  gap: 6px;\n  color: var(--fz-button-fcolor);\n  cursor: pointer;\n  transition: background-color 0.3s, color 0.3s, border-color 0.3s;\n  font-size: 16px;\n  font-style: normal;\n  font-weight: 600;\n  line-height: 24px;\n  height: var(--fz-button-height);\n}\n\n.fz-button:hover {\n  --fz-button-bg: #d2d2d2;\n}\n\n.fz-button:focus {\n  --fz-button-bg: #fff;\n}\n\n.obituaries-shares--wrapper {\n  --share-items-status: none;\n  --share-items-maring: 0;\n  --share-icon-color: #444;\n  --share-icon-border-color: #444;\n}\n\n.obituaries-shares--wrapper .obituarie-shares__title {\n  display: none;\n}\n\n.obituaries-shares--wrapper .obituarie-shares__list {\n  display: var(--share-items-status) !important;\n  gap: 14px;\n}\n\n.obituaries-shares--wrapper.expanded .obituarie-shares__list {\n  --share-items-status: flex;\n}\n\n.obituaries-shares--wrapper .obituarie-shares__item {\n  margin: var(--share-items-maring) !important;\n  border-color: var(--share-icon-border-color) !important;\n}\n\n.obituaries-shares--wrapper .obituarie-shares__item i {\n  color: var(--share-icon-color) !important;\n}\n\n.obituaries-shares--wrapper.expanded .obituarie-shares__button {\n  display: none;\n}\n\n.obituaries-shares--wrapper .obituarie-shares__item--close {\n  width: 50px;\n  height: 50px;\n  background-color: var(--share-icon-bg-color);\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n}\n\n.obituaries-shares--wrapper .obituarie-shares__item:hover,\n.obituaries-shares--wrapper .obituarie-shares__item:focus {\n  background-color: var(--share-icon-hover-color) !important;\n  opacity: 1 !important;\n}\n\n.tippy-box {\n  font-family: var(--tippy-font-family) !important;\n  background-color: var(--tippy-bg-color) !important;\n  color: var(--tippy-font-color) !important;\n  font-size: var(--tippy-font-size) !important;\n  border-radius: var(--tippy-border-radius) !important;\n}\n\n.tippy-box[data-theme~=\"base-white\"] {\n  --tippy-bg-color: #fff;\n  --tippy-font-color: #344054;\n  padding: 8px 12px;\n  line-height: 18px;\n  font-weight: 600;\n  line-height: 18px;\n  height: 42px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.tippy-arrow {\n  color: var(--tippy-bg-color) !important;\n}\n\n.top-obit-nav__share-section {\n  display: none;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  padding: 13px 20px 15px 20px;\n}\n\n.top-obit-nav__share-button {\n  width: 100%;\n}\n\nbody.modal-open:has(.modal-mask.get-tribute-share-modal) {\n  padding-right: 0 !important;\n  overflow-y: auto !important;\n}\n\n.get-tribute-share-modal {\n  --modal-content-width: 483px;\n  --modal-content-radius: 12px;\n  --modal-content-shadow: 0 20px 24px -4px rgba(16, 24, 40, 0.08),\n    0 8px 8px -4px rgba(16, 24, 40, 0.03);\n  --modal-content-padding: 24px;\n  --modal-close-icon-width: 44px;\n  --share-icon-FB: #444;\n  background-color: transparent !important;\n  position: relative !important;\n}\n\n.get-tribute-share-modal .modal-mask__wrapper {\n  background-color: var(--modal-mask-bg) !important;\n  position: fixed;\n  top: 0;\n  left: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 100%;\n  height: 100%;\n  z-index: 9998;\n}\n\n.get-tribute-share-modal .modal-mask__container {\n  padding: var(--modal-content-padding);\n  width: var(--modal-content-width) !important;\n  border-radius: var(--modal-content-radius) !important;\n  box-shadow: var(--modal-content-shadow) !important;\n  max-width: calc(100vw - var(--modal-content-padding));\n  max-height: calc(100vh - var(--modal-content-padding));\n  overflow-y: auto;\n}\n\n.get-tribute-share-modal .modal-mask__close {\n  right: 8px;\n  top: 8px;\n  position: absolute;\n  width: var(--modal-close-icon-width);\n  height: 44px;\n  padding: 8px;\n  cursor: pointer;\n  display: flex;\n}\n\n.share-tribute {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n}\n\n.share-tribute__titles {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n\n.share-tribute__title {\n  color: var(--modal-title-fcolor);\n  font-family: var(--material-font-family);\n  font-size: 18px;\n  font-style: normal;\n  font-weight: 600;\n  line-height: 28px;\n  padding-right: var(--modal-close-icon-width);\n}\n\n.share-tribute__sub {\n  color: #475467;\n  font-family: var(--material-font-family);\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 20px;\n}\n\n.share-tribute__list {\n  --share-icon-color: #444;\n  --share-icon-border-color: #444;\n  --share-icon-font-size: 18px;\n  display: grid;\n  grid-template-columns: repeat(5, 1fr);\n  gap: 16px;\n  justify-content: center;\n}\n\n.share-tribute__item {\n  cursor: pointer;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 16px;\n}\n\n.share-tribute__item--icon {\n  background-color: var(--share-icon-bg-color);\n  border: var(--share-icon-border);\n  border-radius: 50%;\n  width: 50px;\n  height: 50px;\n  color: var(--share-icon-color);\n  font-size: var(--share-icon-font-size);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  transition: background-color 0.3s;\n}\n\n.share-tribute__item:hover .share-tribute__item--icon,\n.share-tribute__item.active .share-tribute__item--icon {\n  background-color: var(--share-icon-hover-color);\n}\n\n.share-tribute__item--icon svg path {\n  fill: var(--share-icon-color);\n}\n\n.share-fb .share-tribute__item--icon {\n  padding-top: 8px;\n}\n\n.share-tw .share-tribute__item--icon svg {\n  width: 16px;\n  height: 16px;\n}\n\n.share-tribute__item--title {\n  font-family: var(--material-font-family);\n  color: var(--share-icon-color);\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 20px;\n}\n\n.share-link {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  text-align: left;\n}\n\n.share-link__label {\n  font-family: var(--material-font-family);\n  color: #344054;\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 20px;\n}\n\n.share-link__inputs {\n  --copy-inputs-gap: 8px;\n  --copy-icon-width: 16px;\n  --copy-font-color: #667085;\n  --copy-line-clamp: 1;\n  border-radius: 8px;\n  border: 1px solid #d0d5dd;\n  background: var(--Base-White);\n  box-shadow: 0 1px 2px 0 rgba(16, 24, 40, 0.05);\n  padding: 8px 12px;\n  display: flex;\n  align-items: center;\n  gap: var(--copy-inputs-gap);\n  cursor: pointer;\n  color: var(--copy-font-color);\n  font-family: var(--material-font-family);\n  font-size: 16px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 24px;\n  width: 100%;\n  height: 40px;\n}\n\n.share-link__inputs.success {\n  --copy-font-color: #008927;\n}\n\n.share-link__inputs svg {\n  width: var(--copy-icon-width);\n  height: var(--copy-icon-width);\n  display: flex;\n  justify-content: end;\n}\n\n.share-link__input-result {\n  color: var(--copy-font-color);\n  overflow: hidden;\n  text-overflow: ellipsis;\n  display: -webkit-box;\n  -webkit-line-clamp: var(--copy-line-clamp);\n  line-clamp: var(--copy-line-clamp);\n  -webkit-box-orient: vertical;\n  width: calc(100% - var(--copy-inputs-gap) - var(--copy-icon-width));\n}\n\n.share-link__copied {\n  display: flex;\n  align-items: center;\n  gap: var(--copy-inputs-gap);\n  flex-grow: 1;\n  width: calc(100% - var(--copy-inputs-gap) - var(--copy-icon-width));\n}\n\n.share-link__copied-text {\n  font-weight: 400;\n}\n\n.share-notify-section {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.share-notify__error-text {\n  color: var(--error-color);\n}\n\n.share-section__title {\n  font-family: var(--material-font-family);\n  color: var(--modal-title-fcolor);\n  font-size: 18px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 28px;\n  text-align: center;\n}\n\n.share-notify__form {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.share-tribute__forms {\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n}\n\n.input-field {\n  border: 1px solid var(--input-border-color);\n  background: var(--Base-White);\n  transition: border-color 0.3s;\n}\n\n.is-invalid .input-field {\n  --input-border-color: var(--error-color);\n}\n\n.input-field::placeholder {\n  color: #757575;\n}\n\n.share-notify__input.input-field {\n  width: 100%;\n  height: 48px;\n  padding: 15px 20px;\n}\n\n.share-notify__row-title {\n  font-family: var(--material-font-family);\n  color: #333;\n  font-size: 16px;\n  font-style: normal;\n  font-weight: 600;\n  line-height: 16px;\n}\n\n.share-notify__row-separator {\n  text-transform: uppercase;\n}\n\n.share-notify__types {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.share-notify__types-list {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n\n.share-notify__types-list .material-checkbox__checkbox-input + .material-checkbox__checkbox-label {\n  display: flex;\n  gap: 7px;\n  align-items: center;\n  padding: 0;\n}\n\n.share-notify__types-list\n  .material-checkbox__checkbox-input\n  + .material-checkbox__checkbox-label::before {\n  position: initial;\n  margin-right: 0;\n}\n\n.btn-form {\n  --btn-bg-color: #444;\n  --btn-font-color: var(--Base-White);\n  --btn-font-size: 20px;\n  --btn-border-color: var(--btn-bg-color);\n\n  display: flex;\n  background-color: var(--btn-bg-color);\n  color: var(--btn-font-color);\n  justify-content: center;\n  align-items: center;\n  gap: 6px;\n  padding: 12px 16px;\n  font-family: var(--material-font-family);\n  font-size: var(--btn-font-size);\n  font-style: normal;\n  font-weight: 600;\n  line-height: normal;\n  transition: background-color 0.3s, color 0.3s;\n  border-radius: 50px;\n  border: 1px solid var(--btn-border-color);\n  width: 100%;\n  cursor: pointer;\n}\n\n.btn-form:hover {\n  --btn-bg-color: #000;\n  --btn-border-color: #666;\n}\n\n.btn-form:disabled {\n  --btn-bg-color: var(--Base-White);\n  --btn-font-color: rgba(102, 102, 102, 0.5);\n  --btn-border-color: var(--btn-font-color);\n  cursor: not-allowed;\n}\n\n.share-tribute-email {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.share-tribute-email__form {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.share-tribute-email__row {\n  display: flex;\n  flex-direction: column;\n  gap: 11px;\n}\n\n.share-tribute-email__label {\n  font-family: var(--material-font-family);\n  color: #3f3f46;\n  font-size: 12px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 16px;\n}\n\n.share-tribute-email__input.input-field {\n  height: 48px;\n  padding: 12px 16px;\n  width: 100%;\n}\n\n.hide-desktop {\n  display: none !important;\n}\n\n.share-tribute__back-button {\n  display: flex;\n  padding: 8px 12px;\n  align-items: center;\n  gap: 4px;\n  color: #475467;\n}\n\n@media (max-width: 768px) {\n  .get-tribute-share-modal {\n    --modal-content-padding: 16px;\n  }\n\n  .get-tribute-share-modal .modal-mask__container {\n    height: auto;\n    max-height: calc(100vh - var(--modal-content-padding) * 2);\n  }\n\n  .modal-enter .modal-mask__container,\n  .get-tribute-share-modal.modal-leave-active .modal-mask__container {\n    transform: scale(1.1);\n  }\n\n  body.modal-open:has(.modal-mask.get-tribute-share-modal) {\n    overflow-y: hidden !important;\n    height: 100vh !important;\n  }\n}\n\n@media (hover: none) and (pointer: coarse) {\n  .share-tribute__item:hover .share-tribute__item--icon {\n    background-color: var(--share-icon-bg-color);\n  }\n\n  .fz-button:hover {\n    --fz-button-bg: var(--Base-White);\n  }\n}\n\n@media (max-width: 1199px) {\n  .top-obit-nav__share-section {\n    display: flex;\n  }\n\n  .get-tribute-share-modal .modal-mask__wrapper {\n    transform: translateY(0);\n  }\n\n  .hide-mobile {\n    display: none !important;\n  }\n\n  .hide-desktop {\n    display: var(--show-desktop) !important;\n  }\n\n  .share-tribute__list {\n    grid-template-columns: repeat(1, 1fr);\n    order: 1;\n  }\n\n  .share-tribute.notify-active .share-tribute__list,\n  .share-tribute.email-active .share-tribute__list {\n    display: none;\n  }\n\n  .share-tribute__item {\n    flex-direction: row;\n    justify-content: start;\n    gap: 8px;\n  }\n\n  .share-tribute.notify-active .share-link,\n  .share-tribute.email-active .share-link {\n    display: none;\n  }\n\n  .share-tribute-email__title {\n    margin: 0 auto;\n  }\n\n  .btn-form.share-tribute-email__button {\n    --btn-font-size: 16px;\n  }\n}</style>", "dependencies": []}, {"id": "10FA81BF-655B-401F-BECF-7DC5E92795DC", "type": "custom_code", "value": function($){document.getElementsByTagName("html")[0].classList.add("CRO-2533-active");

window.ozlyShareSocial = (() => {
  function loadScript({ url, target = document.body, onLoaded, isAsync = true }) {
    const script = document.createElement("script");
    script.src = url;
    script.async = isAsync;
    script.onload = () => onLoaded && onLoaded();
    target.appendChild(script);
  }

  function injectTippy() {
    return new Promise((resolve, reject) => {
      if (window.tippy) {
        resolve();
        return;
      }

      loadScript({
        url: "https://unpkg.com/@popperjs/core@2",
        onLoaded: () => {
          loadScript({
            url: "https://unpkg.com/tippy.js@6",
            onLoaded: resolve
          });
        }
      });
    });
  }

  function setPluginTrippy(target, options = {}) {
    if (typeof window.tippy === "undefined") {
      return;
    }
    return tippy(
      target,
      Object.assign({}, options, {
        placement: "top-end",
        trigger: "mouseenter focus",
        content: (reference) => reference.getAttribute("data-help-text"),
        theme: "base-white"
      })
    );
  }

  function createShareButtons(text = "Share obituary") {
    const button = document.createElement("button");
    button.classList.add("obituarie-shares__button", "fz-button");
    button.type = "button";
    const template = `
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M15.7399 7.40214L10.2402 12.1238C9.75955 12.5394 8.9999 12.2033 8.9999 11.5563V8.83645C4.15293 8.90519 2.06428 10.1083 3.48109 14.6393C3.6383 15.1421 3.0308 15.5318 2.60425 15.2212C1.23713 14.2268 0 12.3269 0 10.4051C0 5.64909 3.98107 4.64289 8.99958 4.58352V2.08426C8.99958 1.43835 9.7583 1.10118 10.2398 1.51679L15.7396 6.23844C16.0868 6.56468 16.0868 7.10215 15.7399 7.40214Z" fill="#444444"/>
    </svg>
    <span class="obituarie-shares__button--text">${text}</span>
  `;
    button.innerHTML = template;
    return button;
  }

  function getUpCurrentUrlUtm({ utm_source, utm_content }) {
    // Get current link and update paramters for UTM
    const currentUrl = new URL(window.location.href);
    currentUrl.searchParams.set("utm_source", utm_source);
    currentUrl.searchParams.set("utm_medium", "referral");
    currentUrl.searchParams.set("utm_campaign", "obituary-share");
    currentUrl.searchParams.set("utm_content", utm_content);
    return currentUrl.toString();
  }

  function getShareLinkWithUtm() {
    return getUpCurrentUrlUtm({
      utm_source: "copy url",
      utm_content: "copy url"
    });
  }

  function openShareTributeModal() {
    window.materialObit.$store.commit("CHANGE_SHARE_TRIBUTE_MODALSTATE", {
      isOpen: true,
      data: {
        shareUrl: getShareLinkWithUtm()
      }
    });
  }

  function shareNative() {
    if (!navigator.share) {
      // Consider providing a fallback UI or alternative sharing method here
      window.ozlyShareSocial.openShareTributeModal();
      return;
    }

    // Get Meta Description
    const metaDescription = document.querySelector('meta[name="description"]');
    const text = (metaDescription && metaDescription.getAttribute("content")) || "";

    const shareData = {
      title: `${MaterialData.user.fullName} Obituary`,
      text: text,
      url: getShareLinkWithUtm()
    };

    navigator.share(shareData);
  }

  function trackingShareButton(text) {
    dataLayer.push({
      event: "ga4Event",
      "ga4.category": "Obituary",
      "ga4.purpose": "Traffic",
      "ga4.location": "Condolence Submission",
      "ga4.action": "Click to Share",
      "ga4.label": text
    });
  }

  function trackingCloseXShareModal() {
    dataLayer.push({
      event: "ga4Event",
      "ga4.category": "Obituary",
      "ga4.purpose": "Traffic",
      "ga4.location": "Obit Menu",
      "ga4.action": "Close Share CTA",
      "ga4.label": "X Button"
    });
  }

  return {
    injectTippy,
    setPluginTrippy,
    createShareButtons,
    shareNative,
    getUpCurrentUrlUtm,
    openShareTributeModal,
    trackingShareButton,
    trackingCloseXShareModal
  };
})();
