const plantedListItems = [
  "Ponderosa Pine",
  "Long Leaf Pine",
  "Jack Pine",
  "White Oak",
  "Western Larch",
  "Lodgepole Pine",
  "Douglas Fir",
  "Red Pine",
  "Loblolly Pine",
  "Slash Pine",
  "Black Spruce"
];

function generatePlantedList(text) {
  const li = document.createElement("li");
  li.textContent = text;
  return li;
}

function createMemorialTreeLink() {
  const href = "memorialtree.com";
  const link = document.createElement("a");
  link.classList.add("faq-accordion__item--link-tree");
  link.href = `https://www.${href}`;
  link.target = "_blank";
  link.textContent = `${href}.`;

  link.addEventListener("click", (e) => {
    e.stopPropagation();
    globalThis.dataLayer.push({
      event: "ga4Event",
      "ga4.category": "PDP",
      "ga4.purpose": "Navigation",
      "ga4.location": "Product Detail",
      "ga4.action": "Tree FAQ Section - Tree Planting Locations",
      "ga4.label": href
    });
  });

  return link;
}

// Tracking when see tree FAQ section
globalThis.ozly2116.trackingEventViewFaq();

utils.waitForElement(".faq-accordion__item-list").then((element) => {
  element.innerHTML = "";
  plantedListItems.forEach((item) => {
    const listItem = generatePlantedList(item);
    element.insertAdjacentElement("beforeend", listItem);
  });
});

// Update description for the fourth item in the FAQ list
utils
  .waitForElement(".faq-accordion__item:nth-child(4) .faq-accordion__item-detail")
  .then((element) => {
    element.textContent = `Your gift of memorial trees will help our nation’s forests in need recover from wildfires, drought, disease, and other natural
disasters.  It also includes a downloadable tree planting certificate you can share with loved ones as a lasting tribute.`;
  });

// Find FAQ last item
utils.waitForElement(".faq-accordion__item:last-child").then((element) => {
  const cloneNewItem = element.cloneNode(true);
  cloneNewItem.classList.remove("active");
  cloneNewItem.classList.add("faq-accordion__item--tree-thirdparty");

  // Update title
  const title = "Want to learn more about memorial tree planting program?";
  cloneNewItem.querySelector(".faq-accordion__item-title").textContent = title;

  const link = createMemorialTreeLink();
  const description = `For more information about our program, FAQs, planting locations, and impact, visit `;
  cloneNewItem.querySelector(".faq-accordion__item-detail").innerHTML = description;
  cloneNewItem.querySelector(".faq-accordion__item-detail").appendChild(link);

  // Insert new item to the end of FAQ list
  element.insertAdjacentElement("afterend", cloneNewItem);
