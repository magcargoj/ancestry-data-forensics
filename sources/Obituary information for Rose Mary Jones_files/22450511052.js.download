7675580751872", "name": "Store - Future Event is possible to delivery ", "conditions": ["and", ["or", ["or", {"match": null, "name": null, "type": "code", "value": "// Order Lead Time is \"2:00\"\nconst { FirstDelivery, FuneralHomeLocalTime, OrderLeadTime } = globalThis.fz_model || {};\n\nfunction covertLeadTimeToNumber(leadTime = \"\") {\n  if (typeof leadTime === \"number\") {\n    return leadTime;\n  }\n  return leadTime.split(\":\").map(Number);\n}\n\nfunction isNotSameDate(date1, date2) {\n  const d1 = new Date(date1);\n  const d2 = new Date(date2);\n  return (\n    d1.getFullYear() !== d2.getFullYear() ||\n    d1.getMonth() !== d2.getMonth() ||\n    d1.getDate() !== d2.getDate()\n  );\n}\n\nfunction convertFuneralHomeOrderLeadTime(funeralHomeDate, leadTimeHours) {\n  const baseDate = new Date(funeralHomeDate);\n  if (Number.isNaN(baseDate.getTime())) {\n    return funeralHomeDate;\n  }\n\n  const normalizedLeadTime = covertLeadTimeToNumber(leadTimeHours);\n  const [hours = 0, minutes = 0] = Array.isArray(normalizedLeadTime)\n    ? normalizedLeadTime\n    : [Number(normalizedLeadTime) || 0, 0];\n\n  baseDate.setHours(baseDate.getHours() + hours);\n  baseDate.setMinutes(baseDate.getMinutes() + minutes);\n  return baseDate;\n}\n\nfunction isPossibleDelivery() {\n  if (!FirstDelivery || FirstDelivery.Start === undefined || !FuneralHomeLocalTime) {\n    return false;\n  }\n\n  const { Start } = FirstDelivery;\n  const firstDeliveryDate = new Date(Start);\n  const funeralHomeLocalTime = new Date(FuneralHomeLocalTime);\n  const funeralHomeLocalLeadTimeHours = convertFuneralHomeOrderLeadTime(\n    funeralHomeLocalTime,\n    OrderLeadTime\n  );\n\n  if (isNotSameDate(firstDeliveryDate, funeralHomeLocalTime)) {\n    return true;\n  }\n\n  // Check lead time in case same day\n  return funeralHomeLocalLeadTimeHours >= firstDeliveryDate;\n}\n\nisPossibleDelivery();\n"}]]]}, {"id": "6612825909493760", "name": "No future events", "conditions": ["and", ["or", ["or", {"match":