 padding: 24px 16px;\n  }\n}</style>", "dependencies": []}, {"id": "2b0b1ebe473140bfb5a87be4dd7806da", "type": "widget", "dependencies": [], "name": "TS Shop badget", "widget_id": "5700721744543744", "config": {"selector": ".ts-customizable-body-host", "insertType": "beforebegin", "bannerMobile": "https://d1uep5tseb3xou.cloudfront.net/content/images/shopBadge-mobile.webp", "bannerDesktop": "https://d1uep5tseb3xou.cloudfront.net/content/images/shopbadget.webp", "href": "#fcb"}}]}, {"viewId": "23548420025", "changes": [{"id": "733add5026aa487e93f23cc7c9ecf075", "type": "append", "selector": "head", "value": "<style>.CRO-2015-active .obituary-info-widget,\n.CRO-2015-active .h-wrapper {\n  display: none !important;\n}\n\n.CRO-2015-active .ts-customizable-body {\n  margin-top: 0;\n  padding-top: 20px;\n}\n\n.CRO-2015-active .ts-custom-header .content {\n  display: flex;\n  align-items: center;\n  padding: 0;\n}\n\n@media only screen and (min-width: 980px) {\n  .CRO-2015-active div.ts-custom-header {\n    height: 200px;\n    display: flex;\n    align-items: center;\n    padding: 10px;\n  }\n}\n\n@media (max-width: 981px) {\n  .CRO-2015-active .breadcrumb li * {\n    vertical-align: top;\n  }\n  .CRO-2015-active .ts-customizable-body {\n    padding-top: 0;\n  }\n}</style>", "dependencies": []}]}, {"viewId": "24926810405", "changes": [{"id": "01213859e9c3496ba03459ad656659cc", "type": "append", "selector": "head", "value": "<style>.CRO-2015-active .obituary-info-widget,\n.CRO-2015-active .h-wrapper {\n  display: none !important;\n}\n\n.CRO-2015-active .obituary-banner {\n  padding-bottom: 9px;\n}\n\n.CRO-2015-active .ts-customizable-body {\n  margin-top: 0;\n}\n\n.CRO-2015-active .ts-custom-header .content {\n  display: flex;\n  align-items: center;\n  padding: 0;\n}\n\n.CRO-2015-active .ts-custom-header .logo a {\n  padding: 0 !important;\n}\n\n@media only screen and (max-width: 980px) {\n  .CRO-2015-active .funeral-home-name {\n    display: flex;\n    justify-content: cen