let shareNavTippyInstance = null;

document.addEventListener("DOMContentLoaded", () => {
  if (typeof window.tippy === "undefined") {
    window.ozlyShareSocial.injectTippy().then(() => {
      window.ozlyShareSocial.setPluginTrippy(".obituarie-shares__item");
    });
  }
});

// Share Obituary in Top Nav for Mobile
function createTopNaveShareObituary() {
  const shareDiv = document.createElement("div");
  shareDiv.classList.add("top-obit-nav__share-section");
  const buttonShare = window.ozlyShareSocial.createShareButtons();
  const textBtn = buttonShare.textContent.trim();
  buttonShare.addEventListener("click", () => {
    window.ozlyShareSocial.trackingShareButton(textBtn);
    window.ozlyShareSocial.shareNative();
  });
  buttonShare.classList.add("top-obit-nav__share-button");

  shareDiv.insertAdjacentElement("afterbegin", buttonShare);
  return shareDiv;
}

function createShareCloseButton() {
  const div = document.createElement("div");
  div.classList.add("obituarie-shares__item", "obituarie-shares__item--close");
  div.setAttribute("data-help-text", "Collapse share options");
  const template = `
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M16.5288 14.2702C17.1537 14.8952 17.1537 15.9076 16.5288 16.5325C16.2188 16.845 15.8088 17 15.3989 17C14.9889 17 14.5799 16.8438 14.268 16.5313L8.99938 11.2654L3.73129 16.53C3.41881 16.845 3.00934 17 2.59988 17C2.19041 17 1.78144 16.845 1.46871 16.53C0.843762 15.9051 0.843762 14.8927 1.46871 14.2677L6.7383 8.99813L1.46871 3.73104C0.843762 3.10609 0.843762 2.09366 1.46871 1.46871C2.09366 0.843762 3.10609 0.843762 3.73104 1.46871L8.99938 6.7408L14.269 1.47121C14.8939 0.846262 15.9063 0.846262 16.5313 1.47121C17.1562 2.09616 17.1562 3.10859 16.5313 3.73354L11.2617 9.00312L16.5288 14.2702Z" fill="#444444"/>
    </svg>
  `;
  div.innerHTML = template;
  return div;
}

// Update Share Obituary into Header Banner of Obituary Page
function updateTopShareElement(shareElement) {
  shareElement.classList.add("obituaries-shares--wrapper");

  // Add share button toggle
  const buttonShareToggle = window.ozlyShareSocial.createShareButtons();
  buttonShareToggle.addEventListener("click", () => {
    shareElement.classList.add("expanded");
    window.ozlyShareSocial.trackingShareButton(buttonShareToggle.textContent.trim());
  });

  // Add close button inside share list
  const shareList = shareElement.querySelector(".obituarie-shares__list");
  if (shareList) {
    const closeButton = createShareCloseButton();
    closeButton.addEventListener("click", () => {
      shareElement.classList.remove("expanded");
      dataLayer.push({
        event: "ga4Event",
        "ga4.category": "Obituary",
        "ga4.purpose": "Traffic",
        "ga4.location": "Obit Menu",
        "ga4.action": "Close Share CTA",
        "ga4.label": "X Button"
      });
    });
    shareList.insertAdjacentElement("beforeend", closeButton);
  }

  shareElement.insertAdjacentElement("afterbegin", buttonShareToggle);
}

function updateNavShareElement(element) {
  element.classList.add("obituaries-shares--wrapper");
  if (shareNavTippyInstance) {
    // Get first object to destroy
    shareNavTippyInstance[0].destroy();
    shareNavTippyInstance = null;
  }

  const initPlugin = () => {
    shareNavTippyInstance = window.ozlyShareSocial.setPluginTrippy(
      ".top-obit-nav__share .obituarie-shares .obituarie-shares__item",
      {
        placement: "bottom-end",
        trigger: "mouseenter focus",
        content: (reference) => reference.getAttribute("data-help-text"),
        theme: "base-white"
      }
    );
  };

  window.requestAnimationFrame(initPlugin);
}

function createBottomNotification() {
  const button = document.createElement("button");
  button.type = "button";
  button.classList.add("fz-button", "signup-notify-button");
  const template = `
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
      <path d="M7.79496 17.4993C8.38257 18.018 9.15444 18.3327 9.99981 18.3327C10.8452 18.3327 11.6171 18.018 12.2047 17.4993M14.9998 6.66602C14.9998 5.33993 14.473 4.06816 13.5353 3.13048C12.5977 2.1928 11.3259 1.66602 9.99981 1.66602C8.67373 1.66602 7.40196 2.1928 6.46428 3.13048C5.5266 4.06816 4.99981 5.33993 4.99981 6.66602C4.99981 9.24117 4.3502 11.0043 3.62453 12.1705C3.01242 13.1542 2.70636 13.6461 2.71758 13.7833C2.73001 13.9352 2.7622 13.9932 2.88463 14.084C2.99519 14.166 3.49364 14.166 4.49052 14.166H15.5091C16.506 14.166 17.0044 14.166 17.115 14.084C17.2374 13.9932 17.2696 13.9352 17.282 13.7833C17.2933 13.6461 16.9872 13.1542 16.3751 12.1705C15.6494 11.0043 14.9998 9.24117 14.9998 6.66602Z" stroke="#344054" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span class="signup-notify-button__text">Sign up for notifications</span>`;
  button.innerHTML = template;
  button.addEventListener("click", () => {
    window.materialObit.$store.commit("CHANGE_GET_UPDATES_MODAL", true);
  });
  return button;
}

utils.waitForElement(".top-info-right .obituarie-shares").then(updateTopShareElement);

const observeNavShare = utils.observeSelector(
  ".top-obit-nav__share .obituarie-shares",
  updateNavShareElement
);

// Replace Share of Memory button in top nav for mobile
utils.waitForElement(".top-obit-nav__memory").then((element) => {
  // Set always hide
  element.classList.add("hide");

  // Create share button after share memory
  const shareTopNaveSection = createTopNaveShareObituary();
  element.insertAdjacentElement("afterend", shareTopNaveSection);
});

// Remove Share socia bottom and replace with notification
utils.waitForElement(".defaultShare.share-bottom").then((element) => {
  element.classList.add("hide");
  const { pageSettings } = window.MaterialData || {};
  if (pageSettings && pageSettings.enableObituaryUpdatesNotification) {
    const buttonNotification = createBottomNotification();
    element.insertAdjacentElement("afterend", buttonNotification);
  }
});

window.addEventListener("beforeunload", () => {
  if (observeNavShare && typeof observeNavShare === "function") {
    observeNavShare();
  }
});
