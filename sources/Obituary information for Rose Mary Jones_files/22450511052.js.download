lex-start;  }  .ts-event-banner__icon {    width: 24px;    height: 24px;    align-self: flex-start;  }  .ts-event-banner__copy {    gap: 4px;    width: calc(100% - 24px - var(--event-banner-content-gap));  }  .ts-event-banner__cta {    display: none;  }}';
