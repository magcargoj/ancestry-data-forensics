window.pushViewMemorialContributeNievent1738 = (element, varaint) => {
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        observer.unobserve(element);
        dataLayer.push({
          event: "niEvent",
          "ga4.category": "Obituary",
          "ga4.purpose": "Ecommerce",
          "ga4.location": "Events List",
          "ga4.action": `niEvent - View Donation Section - CRO-1738 - ${varaint}`,
          "ga4.label": `View Donation - ${varaint}`,
        });
      }
    });
  });

  observer.observe(element);

  window.addEventListener("beforeunload", () => {
    if (observer) {
      observer.unobserve(element);
    }
  });
};
}, "dependencies": []}], "id": "6600461524926464", "name": "CRO-1738 TCO | Altmeyer | Obit | Donation Testing", "commitId": "5059980085166080", "groupId": null, "holdback": 0, "activation": {}, "integrationSettings": {"google_analytics_4": {"is_using_gtm": "on"}}, "integrationStringVersion": 2, "experiments": [{"audienceIds": ["and", "5844800549683200", "28786180345", "24831400393", "27724250398", "5122717897195520"], "audienceName": "Donations are included on the obit,Exclude Tribute Fund / Donation,Dont Test On Me,Frazer/SRS template,CRO-1738 Inclusion Group", "changes": null, "id": "5287374863728640", "integrationSettings": null, "variations": [{"id": "4668536379932672", "name": "Original", "actions": [{"viewId": "5614878778458112", "changes": [{"id": "1644C934-E57A-45F9-A469-560B476BB246", "type": "custom_code", "value": function($){const utils = window.optimizely.get("utils");

