window.ozly2537AbTest = (() => {
  function pushEventNiEvent() {
    dataLayer.push({
      event: "niEvent",
      "ga4.category": "Obituary",
      "ga4.purpose": "Condolence",
      "ga4.location": "Tribute Wall",
      "ga4.action": "niEvent - Tribute Wall",
      "ga4.label": "View Tribute Wall"
    });
  }

  function observeElement(element, callback) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          observer.unobserve(element);
          typeof callback === "function" && callback();
        }
      });
    });

    observer.observe(element);
    return observer;
  }

  function trackingClickPhoto() {
    dataLayer.push({
      event: "ga4Event",
      "ga4.category": "Obituary",
      "ga4.purpose": "Condolence",
      "ga4.location": "Tribute Wall",
      "ga4.action": "Tribute Wall",
      "ga4.label": "Expand Image - Tribute Wall"
    });
  }

  return {
    pushEventNiEvent,
    observeElement,
    trackingClickPhoto
  };
})();
