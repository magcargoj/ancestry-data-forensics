        const utils = window.optimizely.get("utils");

const PRODUCT_OFFERINGS = window.ozly.getDataLayerValue("pageInfo.productsOffered") || "";

const productOfferrings = {
  tree: PRODUCT_OFFERINGS.includes("Trees"),
  flower: PRODUCT_OFFERINGS.includes("Flowers")
};

function getTitleSection() {
  if (extension && extension.title) return extension.title;

  const { tree, flower } = productOfferrings;

  if (tree && flower) return "Send flowers & plant a tree";
  if (tree) return "Plant a tree in memory";
  if (flower) return "Send flowers to the family";
  return "Ways to offer support";
}

function getDescriptionSection() {
  const { tree, flower } = productOfferrings;
  const firstName = window.MaterialData.user.firstName;
  const baseMessage = "Even though there aren't any more events, you can still show support";

  if (tree && flower) {
    return `${baseMessage} by sending flowers or planting a tree in memory of ${firstName}.`;
  }
  if (tree) {
    return `${baseMessage} by planting a tree in memory of ${firstName}.`;
  }
  if (flower) {
    return `${baseMessage} by sending flowers.`;
  }
  return "Even though there aren't any more events";
}

function trackingWatchSection() {
  dataLayer.push({
    event: "niEvent",
    "ga4.category": "Obituary",
    "ga4.purpose": "Event",
    "ga4.location": "Event List",
    "ga4.action": "niEvent - Scheduled Events",
    "ga4.label": "View Get Event Updates"
  });
}

function observeElementPastEvent(element) {
  let hasTracked = false;
  const intersectionCallback = (entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting && !hasTracked) {
        observer.unobserve(element);
        hasTracked = true;
        trackingWatchSection();
      }
    });
  };
  const observer = new IntersectionObserver(intersectionCallback);
  observer.observe(element);
  return observer;
}

// Render the extension
if (extension.selector) {
  utils.waitForElement(extension.selector).then((elem) => {
    const html = extension.$render({
      extension: extension,
      titleSection: getTitleSection(),
      description: getDescriptionSection(),
      isShowButtons: productOfferrings.tree || productOfferrings.flower,
      isBothButtons: productOfferrings.tree && productOfferrings.flower,

      productOfferrings
    });
    elem.insertAdjacentHTML(extension.insertType, html);
  });

  utils.waitForElement(`#optimizely-extension-${extension.$instance}`).then((element) => {
    if (Number.parseInt(extension.isTrackNiEvent) !== 1) {
      return;
    }
    // Observe past event section view and Set NiEvent
    const observer = observeElementPastEvent(element);

    window.addEventListener("beforeunload", () => {
      if (observer) observer.unobserve(element);
    });
  });
}

function getLinkStore(link, source) {
  if (!link) return "#";

  try {
    const url = new URL(link);
    url.searchParams.set("source", source);
    return url.toString();
  } catch (e) {
    // If link is not a valid URL, return fallback
    return "#";
  }
}

function updateButtonLink(selector, link) {
  console.log("Update link button:", link);
  selector.setAttribute("href", link);
  window.requestAnimationFrame(() => {
    selector.classList.add("active");
  });
}

function trackingClickButton(label = "") {
  dataLayer.push({
    event: "ga4Event",
    "ga4.category": "Obituary",
    "ga4.purpose": "Ecommerce",
    "ga4.location": "Event List",
    "ga4.action": "Tribute Wall Click",
    "ga4.label": label
  });
}

// Get Flower Link from top header
if (productOfferrings.flower) {
  utils.waitForElement(".top-obit-nav__btn.btn-material.orange").then((element) => {
    utils
      .waitForElement(`#optimizely-extension-${extension.$instance} .event-past-buttons__flower`)
      .then((flowerButton) => {
        const flowerLink = element.getAttribute("href");
        const eventFlowerLink = getLinkStore(flowerLink, "tco_event");
        updateButtonLink(flowerButton, eventFlowerLink);

        // Add on click
        flowerButton.addEventListener("click", () => {
          trackingClickButton("Send Flowers");
        });
      });
  });
}

// Get Tree Link from top header
if (productOfferrings.tree) {
  utils.waitForElement(".top-obit-nav__btn.btn-material.tree-green").then((element) => {
    utils
      .waitForElement(`#optimizely-extension-${extension.$instance} .event-past-buttons__tree`)
      .then((treeButton) => {
        const treeLink = element.getAttribute("href");
        const eventTreeLink = getLinkStore(treeLink, "tco_event");
        updateButtonLink(treeButton, eventTreeLink);

        // Add on click
        treeButton.addEventListener("click", () => {
          trackingClickButton("Plant A Tree");
        });
      });
  });
}

