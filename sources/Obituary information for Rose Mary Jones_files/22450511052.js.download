changes": null, "id": "6082691725000704", "integrationSettings": null, "variations": [{"id": "5162948084105216", "name": "Variation #1", "actions": [{"viewId": "5953395954024448", "changes": [{"id": "A124C43D-E0B3-437D-B5C3-E0BC6AA06ECE", "type": "custom_code", "value": function($){const utils = window.optimizely.get("utils");
const textFlorist = "By our in-house florist";

function updateGuaranteedMessages() {
  const guaranteedMessage = Array.from(document.querySelectorAll(".guaranteed-message__text"));
  guaranteedMessage.forEach((el) => {
    if (el.textContent.trim() !== textFlorist) {
      el.textContent = textFlorist;
    }
  });
}

function updateGuaranteedTab(element) {
  element.textContent =
    "We work with in-house florists in our community to bring you high-quality, hand-designed arrangements.";
}

utils.waitForElement(".guaranteed-message__text").then(updateGuaranteedMessages);

const cto = setTimeout(() => {
  updateGuaranteedMessages();
  clearTimeout(cto);
}, 500);

utils.waitForElement(".fl-description__list li:nth-of-type(2)").then((li) => {
  li.remove();
});

// Sourced By Our In-House Florist
const overviewCol2 = utils.observeSelector(
  ".product-order-overview__item:nth-of-type(2)",
  (element) => {
    const title = element.querySelector(".product-order-overview__item-title");
    if (title) {
      title.textContent = "Sourced By Our In-House Florist";
    }

    const description = element.querySelector(".product-order-overview__item-description");
    if (description) {
      description.textContent = "Our in-house florist fulfills each order with care";
    }
  }
);

const overviewCol3Des = utils.observeSelector(
  ".product-order-overview__item:nth-of-type(3) .product-order-overview__item-description",
  (element) => {
    element.textContent = "Our in-house florist delivers directly to the services or family home";
  }
);

utils.waitForElement("#tabs-3 .custom-tab > p strong").then(updateGuaranteedTab);

if (window.isFcb === "True") {
  utils
    .waitForElement(".accordion-body__detail.guarantees-detail > p strong")
    .then(updateGuaranteedTab);
}

document.addEventListener("beforeunload", () => {
  if (overviewCol2 && typeof overviewCol2 === "function") {
    overviewCol2();
  }

  if (overviewCol3Des && typeof overviewCol3Des === "function") {
    overviewCol3Des();
  }
});
