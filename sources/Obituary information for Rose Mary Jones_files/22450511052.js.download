ingle_experiment", "viewIds": ["23470791003", "23548420025", "24174540572", "24926810405"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": [{"id": "536B8C17-AAAB-4BBD-9F17-AD3FBAA7615E", "type": "append", "selector": "head", "value": "<style>.CRO-2434-active {\n  --Gray-500-Primary: #71717a;\n  --Gray-700-Primary: #3f3f46;\n  --Font-Lato: \"Lato\", sans-serif;\n  --clp-product-item-mobile: repeat(5, 150px);\n}\n\n.CRO-2434-active .italic {\n  font-style: italic !important;\n}\n\n/*Checkout*/\n.CRO-2434-active .carts-summary--tranparent {\n  border-top: none;\n  margin-top: 0;\n  padding-top: 24px;\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.CRO-2434-active .carts-summary--tranparent .carts-summary__item.is-total {\n  display: flex;\n  margin-top: 0;\n}\n\n.CRO-2434-active .carts-summary--tranparent .carts-summary__item.is-total.for-review {\n  display: none;\n}\n\n.delivery-fee-banner {\n  display: flex;\n  flex-direction: column;\n  margin: 0 auto;\n  gap: 16px;\n  align-items: center;\n  justify-content: center;\n  width: 1014px;\n  max-width: 100%;\n}\n\n.delivery-fee-banner--title {\n  font-family: \"Source Serif Pro\", serif;\n  font-size: 24px;\n  font-weight: 400;\n  line-height: normal;\n  color: var(--Gray-700-Primary);\n  text-align: center;\n}\n\n.delivery-fee-banner--description {\n  color: var(--Gray-500-Primary);\n  text-align: center;\n  font-family: var(--Font-Lato);\n  font-size: 18px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 32px;\n}\n\n@media (max-width: 768px) {\n  .transparent-prices {\n    justify-content: flex-start;\n  }\n\n  .CRO-2434-active .carts-top__detail {\n    padding: 12px 12px 15px 12px;\n  }\n\n  .CRO-2434-active .fc-widget-normal {\n    display: none !important;\n  }\n\n  .delivery-fee-banner--title {\n    font-size: 20px;\n  }\n\n  .delivery-fee-banner--description {\n    font-size: 14px;\n  }\n}</style>", "dependencies": []}, {"id": "113AC41B-2AF2-4D64-8725-9A4E01E3D7BA", "type": "custom_code", "value": function($){document.getElementsByTagName("html")[0].classList.add("CRO-2434-active");

window.formatCurrency = (value) => {
  const currency = window.ozly.getDataLayerValue("siteInfo.currency") === "CAD" ? "C$" : "$";
  return `${currency}${value}`;
};

window.ozlyConvertPrice = (price) => {
  return price ? parseFloat(price.replace(/[^\d.]/g, "")) : 0;
};

window.ozlyFormatStringPrice = (price) => {
  return price.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
};

window.getSelectedTypeProduct = ({ isFlower, isTree, isGrove }) => {
  if (isFlower) return "flowers";
  if (isGrove) return "grove";
  return "singleTrees";
};

window.getStandardFee = (productType = "flowers") => {
  const standardFee = {
    flowers: window.formatCurrency("19.99"),
    singleTrees: window.formatCurrency("7.95"),
    grove: window.formatCurrency("14.95")
  };
  return standardFee[productType];
};

window.getCareHandlingFee = (productType = "flowers") => {
  const careHandlingFee = {
    flowers: window.formatCurrency("4.99"),
    singleTrees: "",
    grove: ""
  };
  return careHandlingFee[productType];
};

window.calulateTotalTransparentPrice = (options = []) => {
  const total = Array.from(options).reduce((acc, item) => {
    const itemPrice = window.ozlyConvertPrice(item);
    return acc + itemPrice;
  }, 0);
  return window.formatCurrency(window.ozlyFormatStringPrice(parseFloat(total).toFixed(2)));
};

window.transparentCheckoutSummaryLines = () => {
  const isFirstPage = () => {
    const pageWrapper = document.querySelector("#page_wrapper");
    return (
      pageWrapper &&
      !["review-page", "thankyou-page"].some((cls) => pageWrapper.classList.contains(cls))
    );
  };

  const createTaxLine = () => {
    const taxLine = document.createElement("div");
    taxLine.classList.add("carts-summary__item");
    taxLine.classList.add("carts-summary__item--tax");
    taxLine.innerHTML = `
      <span class="carts-summary__item-label">Tax</span>
      <span class="carts-summary__item-value">Determined at final step</span>
    `;
    return taxLine;
  };

  const createDeliveryLine = () => {
    const deliveryLine = document.createElement("div");
    deliveryLine.classList.add("carts-summary__item");
    deliveryLine.classList.add("carts-summary__item--delivery");
    deliveryLine.innerHTML = `
      <span class="carts-summary__item-label">Delivery</span>
      <span class="carts-summary__item-value">Included!</span>
    `;
    return deliveryLine;
  };

  const updateItems = (summaryEle, isShowReview = true) => {
    const cart = summaryEle.closest(".carts");
    let typeProduct = window.isMainProductTreeProduct !== "True" ? "flowers" : "singleTrees";

    if (window.isMainProductTreeProduct === "True") {
      const productName = cart.querySelector(".carts-product__item .detail-title");
      const quantityEle = cart.querySelector(".carts-product__item .detail-quantity");
      const quantity = quantityEle
        ? parseInt(quantityEle.textContent.replace("Grove of", "").trim(), 10)
        : 1;
      const name = productName ? productName.textContent : "";
      if (name.toLowerCase().includes("grove") || quantity > 1) {
        typeProduct = "grove";
      }
    }

    const standardFee = window.ozlyConvertPrice(window.getStandardFee(typeProduct));
    const careHandlingFee = window.ozlyConvertPrice(window.getCareHandlingFee(typeProduct));
    const itemFirst = summaryEle.querySelectorAll(".carts-summary__item")[0];

    // ReCalculate the SubTotal
    if (itemFirst && !itemFirst.classList.contains("is-transparent")) {
      const subTotalPriceEle = itemFirst.querySelector(".carts-summary__item-price");
      if (!subTotalPriceEle) return;

      const subTotal = window.ozlyConvertPrice(subTotalPriceEle.textContent);
      const newSubTotal = (subTotal + standardFee + careHandlingFee).toFixed(2);
      itemFirst.querySelector(".carts-summary__item-price").textContent =
        window.formatCurrency(newSubTotal);
      itemFirst.classList.add("is-transparent", "carts-summary__item--subtotal");
    }

    // Remove summary label contain "Standard Fee" and "Care & Handling Fee"
    const summaryLabels = Array.from(summaryEle.querySelectorAll(".carts-summary__item-label"));
    summaryLabels.forEach((label) => {
      const labelText = label.textContent;
      if (labelText.includes("Standard Service") || labelText.includes("Care & Handling")) {
        label.parentElement.classList.add("hide");
      }
    });

    // Update Cart Products Price

    const cartItemPrice = cart
      ? cart.querySelector(".carts-product__item-detail .detail-price")
      : null;
    if (cartItemPrice && !cartItemPrice.classList.contains("detail-price--transparent")) {
      const productPrice = window.ozlyConvertPrice(cartItemPrice.textContent);
      const newPrice = (productPrice + standardFee + careHandlingFee).toFixed(2);
      cartItemPrice.textContent = window.formatCurrency(newPrice);
      cartItemPrice.classList.add("detail-price--transparent");
    }

    if (window.isMainProductTreeProduct !== "True") {
      const summaryItems = Array.from(summaryEle.querySelectorAll(".carts-summary__item"));
      const deliveryLine = createDeliveryLine();
      const deliveryLineExists = summaryItems.some((item) =>
        item.classList.contains("carts-summary__item--delivery")
      );

      if (deliveryLineExists) return;
      // Insert delivery line after the SubTotal item
      if (itemFirst) itemFirst.insertAdjacentElement("afterend", deliveryLine);
    }

    const transparentElement = summaryEle.parentElement.querySelector(".carts-summary--tranparent");

    if (transparentElement) {
      transparentElement.remove();
    }

    const newSummaryContainer = document.createElement("div");
    newSummaryContainer.classList.add("carts-summary--tranparent");

    const summaryItems = Array.from(summaryEle.querySelectorAll(".carts-summary__item"));

    const isExistTax = summaryItems.some((item) => {
      const label = item.querySelector(".carts-summary__item-label");
      return label && label.innerText.includes("Tax");
    });

    summaryItems.forEach((item) => {
      const clonedItem = item.cloneNode(true);
      if (isShowReview) clonedItem.classList.remove("for-review");

      if (clonedItem.classList.contains("is-total")) {
        if (window.isMainProductTreeProduct !== "True") {
          const taxLine = createTaxLine();
          newSummaryContainer.appendChild(taxLine);
        }
      }
      newSummaryContainer.appendChild(clonedItem);
    });

    if (window.isMainProductTreeProduct !== "True" && !isExistTax) {
      const taxLine = createTaxLine();
      taxLine.querySelector(".carts-summary__item-value").textContent = `${window.formatCurrency(
        "0.00"
      )}`;
      const totalItem = summaryEle.querySelector(".carts-summary__item.is-total");
      // Insert tax line before the total item
      if (totalItem) totalItem.insertAdjacentElement("beforebegin", taxLine);
    }

    summaryEle.insertAdjacentElement("afterend", newSummaryContainer);
    if (isFirstPage()) {
      summaryEle.classList.add("hide");
    } else {
      summaryEle.classList.remove("hide");
      newSummaryContainer.classList.add("hide");
    }
  };

  return { updateItems, isFirstPage };
};

window.ozlyDeliveryBannerTemplate = () => {
  const div = document.createElement("div");
  div.classList.add("delivery-fee-banner");
  div.innerHTML = `
    <div class="delivery-fee-banner--title">All-inclusive pricing - no hidden fees</div>
    <div class="delivery-fee-banner--description">Delivery is already included, helping you send sympathy without added stress or surprise costs.</div>
    `;
  return div;
};

/* CLP Transparent Price */
window.ozlyClpTransparentPrice = () => {
  const utils = window.optimizely.get("utils");

  utils.waitForElement(".clp-products-list").then((element) => {
    const productItems = Array.from(element.querySelectorAll(".clp-product-item"));
    productItems.forEach((item) => {
      const price = parseFloat(item.getAttribute("data-price")) || "";
      const name = item.getAttribute("data-name");
      const isTree = name === "Memorial Tree";
      const isGrove = item.getAttribute("data-is-grove") === "True";
      const isFlower = !isTree && !isGrove;
      const typeSelected = window.getSelectedTypeProduct({ isFlower, isTree, isGrove });
      const currentPriceEle = item.querySelector(".current-price");

      const costFees = {
        price: `${window.formatCurrency(price.toFixed(2))}`,
        standardFee: window.getStandardFee(typeSelected),
        tax: "",
        careHandlingFee: window.getCareHandlingFee(typeSelected)
      };

      // Update Product item price
      const totalPrice = window.calulateTotalTransparentPrice(Object.values(costFees));
      if (currentPriceEle) {
        currentPriceEle.innerText = totalPrice;
      }
    });
  });

  utils.waitForElement(".clp-products").then((element) => {
    // Add Delivery Banner
    const deliveryBanner = window.ozlyDeliveryBannerTemplate();
    deliveryBanner.classList.add("clp-section");
    element.insertAdjacentElement("afterend", deliveryBanner);
  });
};

/* PLP Transparent Price */
window.ozlyPlpTransparentPrice = () => {
  const utils = window.optimizely.get("utils");

  const obServeProductItems = utils.observeSelector(
    ".product-grid .item-box .product-item",
    function (element) {
      const detailsElement = element.querySelector(".details");
      if (!detailsElement) {
        return;
      }

      const price = parseFloat(element.getAttribute("data-price")) || "";
      const isTree = element.getAttribute("data-category") === "tree";
      const isGrove = element.getAttribute("data-is-tree-grove") === "true";
      const isFlower = !isTree;
      const typeSelected = window.getSelectedTypeProduct({ isFlower, isTree, isGrove });
      const priceElement = element.querySelector(".actual-price.price");

      const costFees = {
        price: `${window.formatCurrency(price.toFixed(2))}`,
        standardFee: window.getStandardFee(typeSelected),
        tax: "",
        careHandlingFee: window.getCareHandlingFee(typeSelected)
      };

      const totalPrice = window.calulateTotalTransparentPrice(Object.values(costFees));
      if (priceElement) {
        const prefix = isTree ? "For" : "From";
        priceElement.innerText = `${prefix} ${totalPrice}`;
      }
    }
  );

  document.addEventListener("beforeunload", () => {
    if (obServeProductItems && typeof obServeProductItems === "function") {
      obServeProductItems();
    }
  });
};

window.ozlyPlpGenerateDeliveryFee = ({ desktopPosition, mobilePosition }) => {
  const utils = window.optimizely.get("utils");

  const desktopPos = desktopPosition || 4;
  const mobilePos = mobilePosition || 2;

  const isPLPMobileVersion = () => {
    return window.innerWidth < 981;
  };

  const generateDeliveryFee = () => {
    const deliveryBannerSelector = document.querySelector(".delivery-fee-banner");
    const deliveryBanner = deliveryBannerSelector || window.ozlyDeliveryBannerTemplate();
    const targetRow = isPLPMobileVersion() ? mobilePos : desktopPos;
    const productItemsCount = Array.from(document.querySelectorAll(".item-box")).length;
    const itemsBox = Array.from(document.querySelectorAll(".item-box"));
    const itemGrid = document.querySelector(".item-grid");

    if (productItemsCount > targetRow) {
      itemsBox[targetRow].insertAdjacentElement("beforebegin", deliveryBanner);
    } else {
      itemGrid.insertAdjacentElement("afterend", deliveryBanner);
    }
  };

  utils.waitForElement(".product-grid .item-box").then(() => {
    generateDeliveryFee();
  });

  document.addEventListener("ajaxFilterComplete", function (e) {
    utils.waitForElement(".product-grid .item-box").then(() => {
      generateDeliveryFee();
    });
  });

  $(function () {
    let previousScreen = window.innerWidth;
    $(window).on("resize", function () {
      const currentScreen = window.innerWidth;
      if (previousScreen !== currentScreen) {
        generateDeliveryFee();
      }
      previousScreen = currentScreen;
    });
  });
};

window.ozlyFlowerTransparentPrice = () => {
  const utils = window.optimizely.get("utils");

  // FCB
  const isFCB = window.isFcb === "True";

  const isTree = false;
  const isGrove = false;
  const isFlower = true;
  const typeSelected = window.getSelectedTypeProduct({ isFlower, isTree, isGrove });
  const category = "Flower";

  // Function to get the total price
  // return string price
  const getTotalPrice = (price) => {
    const costFees = {
      price,
      standardFee: window.getStandardFee(typeSelected),
      tax: "",
      careHandlingFee: window.getCareHandlingFee(typeSelected)
    };
    return window.calulateTotalTransparentPrice(Object.values(costFees));
  };

  utils.waitForElement(".product-price span[class^=price-value-]").then((priceEle) => {
    const element = priceEle.closest(".product-price");
    const price = priceEle.innerText.trim();
    const totalPrice = getTotalPrice(price);

    // Create a new total price element
    const div = document.createElement("div");
    div.classList.add("product-price__total");
    div.innerText = totalPrice;
    element.insertAdjacentElement("beforeend", div);
  });

  utils.waitForElement(".product-price__total").then((element) => {
    const div = document.createElement("div");
    div.classList.add("product-price__delivery-fee");
    div.innerText = "Delivery included";
    element.insertAdjacentElement("afterend", div);
  });

  utils.waitForElement(".ng-scope .options-group__attribute-size .option-list").then((element) => {
    const items = Array.from(element.querySelectorAll(".option-list__item"));
    items.forEach((item) => {
      const priceText = item.querySelector(".option-list__item-price");
      if (priceText) {
        const price = priceText.innerText.trim();
        const totalPrice = getTotalPrice(price);
        item.setAttribute("data-price", price);
        item.setAttribute("data-total", totalPrice);
        priceText.innerText = totalPrice;
      }
    });
  });

  $(function () {
    $(document).on(
      "change",
      ".options-group__attribute-size .option-list__item-radio:checked",
      function () {
        const $this = $(this);
        const $parent = $this.closest(".option-list__item");
        const totalPrice = $parent.data("total");
        $(".product-price__total").html(totalPrice);
      }
    );
  });
};

window.ozlyTreePdPTransparentPrice = () => {
  const utils = window.optimizely.get("utils");

  const isTree = true;
  const isGrove = window.location.href.includes("grove-of-memorial-trees");
  const isFlower = false;
  const typeSelected = window.getSelectedTypeProduct({ isFlower, isTree, isGrove });

  // Function to get the total price
  // return string price
  const getTotalPrice = (price, quantity = 1) => {
    let type = typeSelected;
    if (quantity > 1) {
      type = "grove";
    }

    const costFees = {
      price,
      standardFee: window.getStandardFee(type),
      tax: "",
      careHandlingFee: window.getCareHandlingFee(type)
    };
    return window.calulateTotalTransparentPrice(Object.values(costFees));
  };

  utils.waitForElement(".price-choices").then((element) => {
    const priceRadios = Array.from(
      element.querySelectorAll(".container-price__button input[type=radio]")
    );

    priceRadios.forEach((radio) => {
      const orignalPrice = radio.getAttribute("data-price");
      const orignalOldPrice = radio.getAttribute("data-price-old");
      const quantity = radio.getAttribute("data-quantity");

      // Create a new attribute to store the original price
      radio.setAttribute("data-orignal-price", orignalPrice);
      radio.setAttribute("data-price", getTotalPrice(orignalPrice, quantity));

      if (orignalOldPrice) {
        // Create a new attribute to store the original old price
        radio.setAttribute("data-orignal-price-old", orignalOldPrice);
        radio.setAttribute("data-price-old", getTotalPrice(orignalOldPrice, quantity));
      }
    });
  });

  // Update the old current Price when the page loads
  utils.waitForElement(".old-product-price span").then((element) => {
    const price = element.innerText.trim();
    const totalPrice = getTotalPrice(price);
    element.innerText = totalPrice;
  });

  // Update the current Price when the page loads
  utils.waitForElement(".product-price span[id*=price-value-]").then((priceEle) => {
    const element = priceEle.closest(".product-price");

    const priceSelected = element.querySelector(
      ".price-choices .container-price__button input[type=radio]:checked"
    );
    let quantity = 1;
    if (priceSelected) {
      quantity = priceSelected.getAttribute("data-quantity");
    }

    const price = priceEle.innerText.trim();
    const totalPrice = getTotalPrice(price, quantity);

    // Create a new total price element
    const div = document.createElement("div");
    div.classList.add("product-price__total");
    div.innerText = totalPrice;
    element.insertAdjacentElement("beforeend", div);
  });

  $(function () {
    $(document).on(
      "change",
      ".price-choices .container-price input[type=radio]:checked",
      function (e) {
        const $this = $(this);
        const totalPrice = $this.data("price");
        $(".product-price__total").html(totalPrice);
      }
    );
  });

  window.addEventListener("pageshow", function (event) {
    // reset the size selection to when page is restored from BFcache
    if (event.persisted || (window.performance && performance.navigation.type === 2)) {
      const sizeSelected = $(".price-choices .container-price.selected");
      if (sizeSelected) {
        sizeSelected.find("input[type=radio]").prop("checked", true);
      }
    }
  });
};

// Checkout Page Transparent Price
window.ozlyCheckoutTransparentPrice = () => {
  const utils = window.optimizely.get("utils");

  const tranparentCheckSummary = window.transparentCheckoutSummaryLines();

  //Sidebar cart
  const orderSummaryObserve = utils.observeSelector(
    ".checkout-page__side .carts-summary",
    (element) => {
      tranparentCheckSummary.updateItems(element, false);
    }
  );

  //Top cart
  const cartTopObserve = utils.observeSelector(".carts-top .carts-summary", (element) => {
    tranparentCheckSummary.updateItems(element, false);

    utils
      .waitForElement(".carts-top .carts-summary__item--subtotal .carts-summary__item-price")
      .then((subTotalEle) => {
        utils.waitForElement(".carts-top .carts-top__tab-total").then((topSummaryEle) => {
          topSummaryEle.innerText = subTotalEle.innerText;
        });
      });
  });

  // Review page in
  const orderDetailCartObserve = utils.observeSelector(
    ".orderDetail-component__box .carts-summary",
    (element) => {
      tranparentCheckSummary.updateItems(element, false);
    }
  );

  document.addEventListener("beforeunload", () => {
    if (orderSummaryObserve && typeof orderSummaryObserve === "function") {
      orderSummaryObserve();
    }

    if (cartTopObserve && typeof cartTopObserve === "function") {
      cartTopObserve();
    }

    if (orderDetailCartObserve && typeof orderDetailCartObserve === "function") {
      orderDetailCartObserve();
    }
  });

  $(function () {
    $(document).on("stepChanged", function (e) {
      const pageActive = e.originalEvent.detail;
      const cartSummary = $(".carts-summary");
      const cartSummaryTransparent = $(".carts-summary--tranparent");
      cartSummary.removeClass("hide");
      cartSummaryTransparent.removeClass("hide");
      if (pageActive !== "checkout") {
        cartSummaryTransparent.addClass("hide");
      }
    });
  });
};
