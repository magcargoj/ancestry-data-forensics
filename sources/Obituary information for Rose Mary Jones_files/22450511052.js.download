const defaultHowItWorksItems = [
  {
    key: "work-1",
    title: "First, you select size and delivery",
    detail: "Pick the arrangement size and tell us where it should go.",
    image:
      "https://tributestoreproducts.s3.us-east-1.amazonaws.com/content/images/feature/work-1.webp"
  },
  {
    key: "work-2",
    title: "Next, florists create your bouquet",
    detail: "Your Designer’s Choice bouquet is crafted with the freshest flowers.",
    image:
      "https://tributestoreproducts.s3.us-east-1.amazonaws.com/content/images/feature/work-2.webp"
  },
  {
    key: "work-3",
    title: "Then, your bouquet is delivered",
    detail: "The Designer’s Choice bouquet will be hand delivered with care.",
    image:
      "https://tributestoreproducts.s3.us-east-1.amazonaws.com/content/images/feature/work-3.webp"
  }
];

if (extension.selector) {
  utils.waitForElement(extension.selector).then((elem) => {
    let customWorkslItems = window.customWorkslItems || defaultHowItWorksItems;
    const html = extension.$render({
      extension: extension,
      customWorkslItems
    });
    elem.insertAdjacentHTML(extension.insertType, html);
  });
}

