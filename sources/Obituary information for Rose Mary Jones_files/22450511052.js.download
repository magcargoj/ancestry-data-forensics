globalThis.ozly2116 = (() => {
  const utils = window.optimizely.get("utils");

  function trackingTreeFAQ() {
    dataLayer.push({
      event: "niEvent",
      "ga4.category": "PDP",
      "ga4.purpose": "Navigation",
      "ga4.location": "Product Detail",
      "ga4.action": "Tree FAQ Section",
      "ga4.label": "niEvent - View Tree FAQ"
    });
  }

  // Tracking when see tree FAQ section
  function trackingEventViewFaq() {
    utils.waitForElement(".faq-accordion").then((element) => {
      let hasTracked = false;
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!hasTracked && entry.isIntersecting) {
            hasTracked = true;
            trackingTreeFAQ();
            observer.unobserve(element);
          }
        });
      });

      observer.observe(element);

      const handleBeforeUnload = () => {
        observer.disconnect();
        globalThis.removeEventListener("beforeunload", handleBeforeUnload);
      };

      globalThis.addEventListener("beforeunload", handleBeforeUnload);
    });
  }

  return { trackingEventViewFaq };
})();
