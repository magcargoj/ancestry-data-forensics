const selectorWallItem = ".tribute-wall__isotope .item.element-item";
const greenBannerCls = "card-wall-green-banner";

const DC_IMAGE_BANNER =
  "https://d1uep5tseb3xou.cloudfront.net/content/images/feature/design-choice-banner.webp";

function formatWallItemDate(dateString) {
  if (!dateString) return "";

  // Set Timezone
  materialObit.$moment.tz.setDefault("America/Resolute");

  const now = materialObit.$moment();
  const serverTime = materialObit.$moment(dateString).format();
  const utc = materialObit.$moment(serverTime).utc().format();
  const timeZone = materialObit.$moment.tz.guess();
  const localTime = materialObit.$moment(utc).tz(timeZone).format();
  const hoursDiff = materialObit.$moment(now).diff(localTime, "hours");
  const dateFormat = materialObit.$moment(localTime);
  const IS_SAME_DAY = 24;
  if (hoursDiff < IS_SAME_DAY) {
    return hoursDiff >= 22 ? `${hoursDiff} hours ago` : dateFormat.fromNow();
  }
  return dateFormat.format("MMM. D, YYYY");
}

function isValidUrl(string) {
  try {
    new URL(string);
    return true;
  } catch (err) {
    return false;
  }
}

function renderBookFooter(element, isLast = true) {
  if (!element) return;
  element.classList.remove("no-border-top");
  element.classList.add(greenBannerCls);
  if (!isLast) element.classList.add("no-radius-bottom");

  const bookIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="30" viewBox="0 0 24 30" fill="none">
    <rect x="6" y="7" width="11" height="18" fill="#98A2B3"/>
    <path d="M6.04426 8.60366L14.5391 4.49879L14.5391 21.5L6.14244 24.6927L6.04426 8.60366Z" fill="white"/>
    <path d="M3.02473 8.10366L11.5195 3.99879L11.5195 21L3.12291 24.1927L3.02473 8.10366Z" fill="#98A2B3"/>
    </svg>`;

  const createLinkBook = () => {
    const link = document.createElement("a");
    link.classList.add("tribute-book__comment--link");
    link.href = `https://www.tributebook.com/domains/${window.domain_id}/obituaries/${window.obit_id}/book`;
    link.target = "_blank";
    link.rel = "noopener";
    link.innerText = `Posted to the Tribute Book for ${window.MaterialData.user.firstName}`;
    return link;
  };

  const cardText = element.querySelector(".card-block__text");
  if (cardText) {
    cardText.innerHTML = "";
    cardText.appendChild(createLinkBook());
  }

  const cardIcon = element.querySelector(".text-block__ico");
  if (cardIcon) {
    cardIcon.innerHTML = bookIcon;
  }
}

function createTitleHighlight(title, icon) {
  const titleWrapper = document.createElement("div");
  titleWrapper.classList.add("card-block--title");
  let template = `<div class="card-block--title-text">${title}</div>`;
  if (icon) {
    template = `<div class="card-block--title-icon">${icon}</div>${template}`;
  }
  titleWrapper.innerHTML = template;
  return titleWrapper;
}

function getCommentMedia(comment) {
  const { ObituaryMedias } = comment;
  if (!ObituaryMedias || ObituaryMedias.length === 0 || !ObituaryMedias[0].Media) return null;
  return ObituaryMedias[0];
}

function createBannerStore(comment) {
  if (!comment) return;
  const { CommentTypeId } = comment;

  const div = document.createElement("div");
  div.classList.add("card__store--cover");

  // Create Background Product Image
  const bgImage = document.createElement("div");
  bgImage.classList.add("card__store--cover__bg");

  // Flower Product
  if (CommentTypeId === window.materialObit.$root.COMMENT_TYPES.Product) {
    const { Media } = getCommentMedia(comment) || {};
    let image = null;
    if (Media) {
      image = Media.Url || Media.ThumbnailUrl || null;
      if (Media.Name === "Designer's Choice Bouquet") {
        image = DC_IMAGE_BANNER;
      }
    }
    if (!image) return;
    bgImage.style.backgroundImage = `url(${image})`;
  } else {
    // Tree Product
    const image = "https://d1uep5tseb3xou.cloudfront.net/content/images/feature/trees-g.webp";
    bgImage.style.backgroundImage = `url(${image})`;
  }

  div.appendChild(bgImage);
  return div;
}

function createBannerStoreTextHighlight({ storeElement, comment }) {
  if (!comment) return;
  const { CommentTypeId } = comment;

  const linkNames = {
    [window.materialObit.$root.COMMENT_TYPES.Product]: "Also send flowers to the family",
    [window.materialObit.$root.COMMENT_TYPES.Tree]: "Also plant a tree in memory",
    [window.materialObit.$root.COMMENT_TYPES.FreeTree]: "Also plant a tree in memory",
    [window.materialObit.$root.COMMENT_TYPES.PremiumTree]: "Also plant a tree in memory"
  };

  const div = document.createElement("div");
  div.classList.add("card__store--cover__highlight");

  // Title
  const title = document.createElement("div");
  title.classList.add("card__store--cover__highlight-title");

  const linkProduct = storeElement.querySelector(".store-block__button");

  if (linkProduct) {
    linkProduct.classList.add("card__store--cover__highlight-link");
  }

  if (linkProduct && linkNames[CommentTypeId]) {
    linkProduct.innerText = linkNames[CommentTypeId];
  }

  // Flower Product
  if (CommentTypeId === window.materialObit.$root.COMMENT_TYPES.Product) {
    const { Media } = getCommentMedia(comment) || {};
    const productName = Media.Name || "Product";
    let titleText = `${productName}  was gifted`;
    if (parseInt(comment.TreeQuantity) > 0) {
      titleText += ` and a memorial tree was planted`;
    }
    title.innerText = titleText;
  } else {
    // Tree Product
    const treeQuantity = parseInt(comment.TreeQuantity) || 1;
    let titleText = "A memorial tree was planted";
    if (treeQuantity > 1) {
      titleText = `A grove of ${treeQuantity} memorial trees was planted`;
    }
    title.innerText = titleText;
  }

  div.insertAdjacentElement("afterbegin", title);
  if (linkProduct) {
    window.requestAnimationFrame(() => {
      div.insertAdjacentElement("beforeend", linkProduct);
    });
  }
  return div;
}

function renderCreateDate(element, currentComment) {
  if (!element || !currentComment) return;

  const { CreatedOn } = currentComment;
  const formattedDate = formatWallItemDate(CreatedOn);
  if (formattedDate) element.innerText = formattedDate;
}

function renderTributeVideo({ element, isHighlight = false }) {
  if (!element) return;

  const titleVideo = element.querySelector(".third-video-title");
  if (titleVideo) {
    isHighlight && titleVideo.classList.add(greenBannerCls);
    titleVideo.innerText = `Tribute Video for ${window.MaterialData.user.fullName}`;
  }

  const thumbBg = element.querySelector(".third-video-block__thumb-bg");
  const playIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none">
    <path d="M24 0C37.2548 0 48 10.7452 48 24C48 37.2548 37.2548 48 24 48C10.7452 48 0 37.2548 0 24C0 10.7452 10.7452 0 24 0ZM20.25 15.1963C19.2501 14.6376 18.0002 15.3364 18 16.4541V31.5459C18.0002 32.6636 19.2501 33.3624 20.25 32.8037L33.75 25.2578C34.75 24.6989 34.75 23.3011 33.75 22.7422L20.25 15.1963Z" fill="black" fill-opacity="0.75"/>
  </svg>`;
  if (thumbBg) {
    const playSection = document.createElement("div");
    playSection.classList.add("third-video-block__thumb-play");
    playSection.innerHTML = playIcon;
    thumbBg.insertAdjacentElement("beforeend", playSection);
  }

  const avatarBg = element.querySelector(".third-video__avatar-bg");
  const thumbUrl = MaterialData.pageSettings.obituaryImageWebp;
  // if thumbUrl check real url
  if (avatarBg && thumbUrl && isValidUrl(thumbUrl)) {
    // Base Thumbnail replace with Image
    const url = new URL(thumbUrl);
    url.pathname = url.pathname.replace("Thumbnail", "Image");
    window.requestAnimationFrame(() => {
      avatarBg.style.backgroundImage = `url(${url.toString()})`;
    });
  }
}

function renderPdf(element) {
  if (!element) return;

  const titleEle = createTitleHighlight("Printable Page");
  element.insertAdjacentElement("afterbegin", titleEle);

  const pdfInner = element.querySelector(".pdf-block__inner");
  if (pdfInner) {
    let template = `<div class="pdf-block__text">A page you can print and share</div>`;
    pdfInner.innerHTML = template;
    if (element.__vue__ && element.__vue__.$data && element.__vue__.$data.pdfUrl) {
      const pdfLink = document.createElement("a");
      pdfLink.classList.add("pdf-block__link", "btn-material", "white-dark");
      pdfLink.href = element.__vue__.$data.pdfUrl;
      pdfLink.target = "_blank";
      pdfLink.innerText = "Print a copy";
      pdfInner.insertAdjacentElement("beforeend", pdfLink);
    }
  }
}

function renderWebCast(element) {
  if (!element) return;

  const icon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
<foreignObject x="0" y="0" width="24" height="24"><div xmlns="http://www.w3.org/1999/xhtml" style="backdrop-filter:blur(8px);clip-path:url(#bgblur_0_33275_13512_clip_path);height:100%;width:100%"></div></foreignObject><g data-figma-bg-blur-radius="16">
<rect width="24" height="24" rx="12" fill="white"/>
<path d="M12 0C18.6274 0 24 5.37258 24 12C24 18.6274 18.6274 24 12 24C5.37258 24 0 18.6274 0 12C0 5.37258 5.37258 0 12 0ZM10.125 7.59863C9.625 7.31916 9 7.6686 9 8.22754V15.7725C9 16.3314 9.625 16.6808 10.125 16.4014L16.875 12.6289C17.375 12.3494 17.375 11.6506 16.875 11.3711L10.125 7.59863Z" fill="#343A40" fill-opacity="0.75"/>
</g>
<defs>
<clipPath id="bgblur_0_33275_13512_clip_path" transform="translate(16 16)"><rect width="24" height="24" rx="12"/>
</clipPath></defs>
</svg>`;

  const titleEle = createTitleHighlight("Live Webcast", icon);
  element.insertAdjacentElement("afterbegin", titleEle);

  const webcastText = element.querySelector(".webcast-video-block__text");
  if (webcastText) {
    webcastText.innerText = `Join a live webcast of ${window.MaterialData.user.firstName}'s service`;
  }
}

function renderStoreCard({ element, comment }) {
  if (!element || !comment) return;

  const cardInner = element.querySelector(".card__inner");
  const storeInner = element.querySelector(".store-block__inner");
  const bannerStore = createBannerStore(comment);
  const bannerHightlight = createBannerStoreTextHighlight({ storeElement: element, comment });

  const normalTreeTypes = [
    window.materialObit.$root.COMMENT_TYPES.Tree,
    window.materialObit.$root.COMMENT_TYPES.FreeTree
  ];

  if (!cardInner || !bannerStore) return;

  element.classList.add("card_store--banner");
  if (bannerHightlight) {
    bannerStore.insertAdjacentElement("beforeend", bannerHightlight);
  }

  if (storeInner && normalTreeTypes.includes(comment.CommentTypeId)) {
    storeInner.classList.add("hide");
  }

  // Create Banner Store
  cardInner.insertAdjacentElement("afterbegin", bannerStore);
}

function renderSymbol(element) {
  if (!element) return;
  const symbolText = element.querySelector(".symbol-block__text");
  if (symbolText) {
    // Remove Period at the end
    symbolText.innerText = symbolText.innerText.trim().replace(/\.$/, "");
  }
}

function renderWall(element) {
  const commentId = element.getAttribute("data-comment-id");
  const comments = materialObit.$store.getters.GET_WALLCOMMENTS_ARRAY;
  const currentComment = comments.find((item) => item.Id == commentId);

  if (!currentComment) return;

  const cardSubComment = element.querySelector(".card__sub-comment");

  // Store Card
  const cardStore = element.querySelector(".card_store");
  const allowBannerStoreCardType = [
    window.materialObit.$root.COMMENT_TYPES.Product,
    window.materialObit.$root.COMMENT_TYPES.Tree,
    window.materialObit.$root.COMMENT_TYPES.FreeTree,
    window.materialObit.$root.COMMENT_TYPES.PremiumTree
  ];

  if (cardStore && allowBannerStoreCardType.includes(currentComment.CommentTypeId)) {
    renderStoreCard({ element: cardStore, comment: currentComment });
  }

  // Tribute Video Block
  const cardTributeVideo = element.querySelector(".third-video-block");
  renderTributeVideo({ element: cardTributeVideo, isHighlight: true });

  // PDF Block
  const pdfBlock = element.querySelector(".pdf-block");
  renderPdf(pdfBlock);

  // Webcast Block
  const webcastBlock = element.querySelector(".webcast-video-block");
  renderWebCast(webcastBlock);

  // Symbol Block
  const symbolBlock = element.querySelector(".symbol-block");
  renderSymbol(symbolBlock);

  // Change book Footer
  const bookFooter = element.querySelector(".card-block__inner.tribute-book__comment");
  const isLast = !cardSubComment;
  renderBookFooter(bookFooter, isLast);

  window.requestAnimationFrame(() => {
    window.dispatchEvent(new Event("resize"));
  });
}

utils.waitForElement(".tribute-wall__isotope").then((wallsElement) => {
  const observeWallItems = utils.observeSelector(selectorWallItem, renderWall);

  // Observe User Block to change create date
  const observeUserBlock = utils.observeSelector(".material-vue .user-block", (element) => {
    const createDate = element.querySelector(".user-block__create");
    if (element.__vue__ && element.__vue__.$props) {
      renderCreateDate(createDate, element.__vue__.$props.comment);
    }
  });

  // Clear Observe
  document.addEventListener(
    "beforeunload",
    () => {
      if (observeWallItems && typeof observeWallItems === "function") {
        observeWallItems();
      }

      if (observeUserBlock && typeof observeUserBlock === "function") {
        observeUserBlock();
      }
    },
    { once: true }
  );
});

utils.waitForElement(".tribute-wall__header").then((element) => {
  // Observe NI Event
  const observeNiEvent = window.ozly2537AbTest.observeElement(element, () => {
    window.ozly2537AbTest.pushEventNiEvent();
  });

  document.addEventListener(
    "beforeunload",
    () => {
      if (observeNiEvent) {
        observeNiEvent.unobserve(element);
      }
    },
    { once: true }
  );
});

jQuery(function () {
  jQuery(document).on("click", ".card_photo .photo-block__photo", function () {
    window.ozly2537AbTest.trackingClickPhoto();
  });
});
}, "dependencies": []}, {"id": "447973c5b1e24cefb033e65cb5bc6dc6", "type": "append", "selector": "head", "value": "<style>.CRO-2537-active .tribute-wall__isotope .card {\n  border-radius: 8px;\n  /*border: 1px solid var(--Gray-100);*/\n  border-top: 1px solid var(--Gray-100);\n  border-left: 1px solid var(--Gray-100);\n  border-right: 1px solid var(--Gray-100);\n  background: var(--Base-White);\n  box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.1);\n}\n\n.hide {\n  display: none !important;\n}\n\n.card-wall-green-banner {\n  background: var(--Wall-BG-Highlight) !important;\n  border-radius: var(--radius-LR);\n}\n\n.card-block--title {\n  background: var(--Wall-BG-Highlight);\n  display: flex;\n  padding: 12px;\n  justify-content: center;\n  align-items: center;\n  color: var(--Gray-700);\n  font-family: var(--Material-Font-Family);\n  font-size: 16px;\n  font-style: normal;\n  font-weight: 700;\n  line-height: normal;\n  letter-spacing: 1px;\n  border-radius: 8px 8px 0 0;\n  height: 44px;\n  width: 100%;\n  gap: 12px;\n}\n\n/* Text Type */\n.CRO-2537-active .tribute-wall__v2 .card__text-wrapper {\n  padding: var(--Space-16-LRB);\n  color: var(--Text-Wall-Color);\n  line-height: 24px;\n}\n\n.CRO-2537-active .tribute-wall__v2 .user-block__title {\n  color: var(--Text-Wall-Color);\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 24px;\n  padding-bottom: 0;\n}\n\n.CRO-2537-active .tribute-wall__v2 .user-block__create {\n  color: var(--Gray-400);\n  font-size: 12px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: normal;\n}\n\n/*Book Footer*/\n.CRO-2537-active .tribute-wall__v2 .tribute-book__comment.card-wall-green-banner {\n  color: var(--Gray-700);\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 400;\n  line-height: 24px;\n  font-family: var(--Material-Font-Family);\n  padding: var(--Wall-Space-Highlight);\n  display: flex;\n  gap: 6px;\n  align-items: center;\n}\n\n.CRO-2537-active .tribute-wall__v2 .tribute-book__comment.card-wall-green-banner.no-radius-bottom {\n  border-bottom-left-radius: 0;\n  border-bottom-right-radius: 0;\n}\n\n.tribute-book__comment.card-wall-green-banner .text-block__ico {\n  margin-right: 0;\n  display: flex;\n  align-items: center;\n  width: 24px;\n  height: 30px;\n}\n\n.tribute-book__comment.card-wall-green-banner .tribute-book__comment--link {\n  text-decoration: none;\n  color: var(--Gray-700);\n}\n\n/* Photo Type */\n.CRO-2537-active .tribute-wall__v2 .photo-block__photos_four .photo-block__list {\n  gap: 14px;\n}\n\n.CRO-2537-active .tribute-wall__v2 .photo-block__photos_two .photo-block__list {\n  gap: 8px;\n}\n\n.CRO-2537-active .tribute-wall__v2 .card_photo .card__inner .card__media {\n  padding: 16px;\n}\n\n/* signature before media */\n.CRO-2537-active .tribute-wall__v2 .card_photo .card__inner .card-signature + .card__media {\n  padding-top: 0;\n}\n\n/* Media before signature */\n.CRO-2537-active .tribute-wall__v2 .card_photo .card__inner .card__media + .card-signature {\n  padding-top: 0;\n}\n\n.CRO-2537-active .tribute-wall__v2 .photo-block__list {\n  margin: 0;\n}\n\n/* Third Video */\n.CRO-2537-active .card__third-video .third-video-block__thumb {\n  display: flex;\n  flex-direction: column;\n}\n\n.CRO-2537-active .third-video-title.card-wall-green-banner {\n  order: 1;\n  padding: 10px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: var(--Gray-700);\n  font-family: var(--Material-Font-Family);\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 300;\n  line-height: 24px;\n}\n\n.CRO-2537-active .card_third-video .card__third-video .third-video-block__thumb-bg {\n  /*margin: 0 16px 16px;*/\n  display: block;\n  height: 416px;\n  padding: 16px;\n}\n\n.CRO-2537-active .card_third-video .card__third-video .third-video__static-bg,\n.CRO-2537-active .card_third-video .card__third-video .photo-block__video {\n  display: none;\n}\n\n.CRO-2537-active .card_third-video .card__third-video .third-video__avatar-bg {\n  width: 100%;\n  height: 100%;\n  position: static;\n  display: block;\n  background-size: cover;\n  transform: none;\n}\n\n.CRO-2537-active .third-video-block__thumb-play {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  cursor: pointer;\n  background: #fff;\n  border-radius: 50%;\n  height: 48px;\n  width: 48px;\n}\n\n.CRO-2537-active .modal-mask.comment-desktop-modal .third-video-title {\n  display: none;\n}\n\n/* Pdf type */\n.CRO-2537-active .pdf-block .card-signature {\n  display: none;\n}\n\n.CRO-2537-active .tribute-wall__v2 .pdf-block__inner {\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  padding: 16px;\n  gap: 16px;\n}\n\n.CRO-2537-active .tribute-wall__v2 .pdf-block__text {\n  font-size: 16px;\n}\n\n.CRO-2537-active .pdf-block__link.btn-material,\n.CRO-2537-active .tribute-wall__v2 .card__third-video .webcast-video-block .webcast-btn {\n  padding: 4px 22px;\n  height: 44px;\n  display: flex;\n  align-items: center;\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 600;\n  line-height: 20px;\n  color: var(--Text-Wall-Color);\n}\n\n/* Webcast link */\n.CRO-2537-active .tribute-wall__v2 .card__third-video .webcast-video-block {\n  padding: 0;\n}\n\n.CRO-2537-active .card__third-video .webcast-video-block .third-video-block__thumb {\n  padding: 16px;\n  gap: 16px;\n}\n\n.CRO-2537-active .tribute-wall__v2 .card__third-video .webcast-video-block .photo-block__title {\n  display: none;\n}\n\n.CRO-2537-active .tribute-wall__v2 .card__third-video .webcast-video-block .webcast-btn:hover {\n  color: #fff;\n}\n\n/* Store Card*/\n.CRO-2537-active .tribute-wall__v2 .card_store--banner .card__store {\n  padding: 16px;\n}\n\n.CRO-2537-active .tribute-wall__v2 .card_store--banner .card__user {\n  display: none;\n}\n\n.CRO-2537-active .tribute-wall__v2 .card_store--banner .store-block .card-signature {\n  order: 1;\n}\n\n.CRO-2537-active .tribute-wall__v2 .card_store--banner .store-block {\n  gap: 16px;\n}\n\n.CRO-2537-active .card_store--banner .store-block__inner.store-block__inner--product {\n  display: none;\n}\n\n.CRO-2537-active .card__store--cover {\n  display: flex;\n  flex-direction: column;\n  width: 100%;\n}\n\n.CRO-2537-active .card__store--cover__bg {\n  height: 125px;\n  background: lightgray 50% / cover no-repeat;\n}\n\n.CRO-2537-active .card_store--banner .store-block__inner--tree-addon {\n  display: none;\n}\n\n.CRO-2537-active .card__store--cover__highlight {\n  background-color: var(--Wall-BG-Highlight);\n  padding: 12px 16px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n}\n\n.CRO-2537-active .card__store--cover__highlight-title {\n  color: var(--Gray-700);\n  font-family: var(--Material-Font-Family);\n  font-size: 14px;\n  font-style: normal;\n  font-weight: 300;\n  line-height: normal;\n  width: 187px;\n}\n\n.CRO-2537-active\n  .card__store--cover__highlight\n  .card__store--cover__highlight-link.store-block__button {\n  color: var(--Gray-700);\n  text-align: center;\n  font-family: var(--Material-Font-Family);\n  font-size: 12px;\n  font-style: normal;\n  font-weight: 300;\n  line-height: normal;\n  background: transparent;\n  text-decoration: underline;\n}\n\n.CRO-2537-active .tribute-wall__v2 .card-store__free-tree .store-block__button.tree-store {\n  color: var(--Gray-700);\n}\n\n.CRO-2537-active .card-store__free-tree .card__store--cover {\n  margin-bottom: 16px;\n}\n\n.CRO-2537-active .card-store__free-tree .card__store {\n  display: none;\n}\n\n.CRO-2537-active .tribute-wall__v2 .card__store.tree-premium .store-block__img {\n  display: none;\n}\n\n.CRO-2537-active .tribute-wall__v2 .card_store__tree-premium .store-block__inner .card-signature {\n  padding: 0;\n}\n\n.CRO-2537-active\n  .tribute-wall__v2\n  .card_store__tree-premium\n  .store-block__inner\n  .card__text-wrapper {\n  padding: 0;\n}\n\n.CRO-2537-active\n  .tribute-wall__v2\n  .card_store__tree-premium\n  .store-block__inner.store-block__inner-nomessage {\n  padding: 0;\n}\n\n/* Candle Type */\n.CRO-2537-active .card_candle .card__inner {\n  display: flex;\n  flex-direction: column;\n}\n\n.CRO-2537-active .card_candle .card-signature {\n  order: 1;\n}\n\n.CRO-2537-active .tribute-wall__v2 .card__candle {\n  padding: 12px 16px;\n  background-color: var(--Wall-BG-Highlight);\n  order: 2;\n}\n\n.CRO-2537-active .card_candle .card__sub-comment {\n  order: 3;\n}\n\n.CRO-2537-active .card__candle .symbol-block__inner {\n  gap: 16px;\n}\n\n.CRO-2537-active .card__candle .symbol-block__photo {\n  margin-right: 0;\n}\n\n.CRO-2537-active .tribute-wall__v2 .symbol-block__text {\n  font-size: 14px;\n  font-weight: 400;\n  color: var(--Gray-700);\n}\n\n/* Book Banner Type*/\n.CRO-2537-active .card-book-banner__title {\n  order: 1;\n  background-color: var(--Wall-BG-Highlight);\n  color: var(--Gray-700);\n  margin-top: -16px;\n  padding: 12px 39px;\n}\n\n.CRO-2537-active .card-book-banner__cover {\n  order: 0;\n}\n\n.CRO-2537-active .card-book-banner__cover img {\n  height: 80px;\n}\n\n.CRO-2537-active .card-book-banner__content {\n  order: 2;\n  padding: 0 16px;\n}\n\n.CRO-2537-active .card-book-banner__cta {\n  order: 3;\n}\n\n@media only screen and (min-width: 768px) {\n  /* Text Type */\n  .CRO-2537-active .tribute-wall__v2 .card__text-wrapper {\n    padding: var(--Space-16-LRB);\n  }\n}</style>", "dependencies": []}]}]}], "weightDistributions": [{"entityId": "5854070242541568", "endOfRange": 5000}, {"entityId": "6362155931402240", "endOfRange": 10000}], "name": "(DRAFT) CRO-2537 TCO | Redesign TW Post Styling Mk 2", "bucketingStrategy": null, "experimentMetadata": {"allocationPolicy": "manual", "layerId": "6413338821787648"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["23529631800"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": null, "id": "6566576812457984", "name": "(DRAFT) CRO-2464 TS | Non-event obits | Change PDP default address from 'custom' to 'family address'", "commitId": "5640442679656448", "groupId": null, "holdback": 0, "activation": {}, "integrationSettings": {"google_analytics_4": {}}, "integrationStringVersion": 2, "experiments": [{"audienceIds": ["and", "23582011142", "27830090031", "24070870642", "25989253250", "25991192436", "27861920090", "4652099238100992", "6069222653034496", "6219055103737856"], "audienceName": "Prod QA,Flower Store Site,Not Tree PDP,Stores 'Dont Test on Me' List,ProductsOffered contain Flowers,Exclude Cemetery Flowers Stores,Obits with no events,Do not run on third-party stores,Exclusion Store for CRO-2464", "changes": null, "id": "5767665784979456", "integrationSettings": null, "variations": [{"id": "6616198247350272", "name": "Original", "actions": [{"viewId": "6535036179054592", "changes": []}]}, {"id": "4919050174726144", "name": "Variation #1", "actions": [{"viewId": "6535036179054592", "changes": [{"id": "43C9BA67-0A90-4DC6-8023-423110CEE090", "type": "custom_code", "value": function($){const utils = window.optimizely.get("utils");
utils
  .waitForElement(".delivery-section .attributes-delivery .attributes.ng-scope")
  .then((element) => {
    const scope = window.angular.element(element).scope();
    const CUSTOM_ADDRESS = "Custom Address";
    const locationOptions = window.fz_model.LocationTypes
      ? JSON.parse(window.fz_model.LocationTypes)
      : [];
    const isCustomAddressEnabled =
      locationOptions.length > 0
        ? locationOptions.some((item) => item.Name === CUSTOM_ADDRESS && item.IsEnabled)
        : false;
    if (scope && isCustomAddressEnabled) {
      scope.$apply(() => {
        scope.EditDeliveryLocation();
        scope.locationTypeUpdate(CUSTOM_ADDRESS);
      });
    }
