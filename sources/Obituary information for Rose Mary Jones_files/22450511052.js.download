  var utils = optimizely.get('utils');
  utils.observeSelector('#topObitsNav .top-obit-nav__btn.btn-material.orange', function () {
    const onButtonClick = function () {
      const dId = window.ozly.getDataLayerValue('pageInfo.tcoObitId');
      const dImg = $('img.avatar').attr('src').split('/').slice(-1)[0];
      const dName = encodeURIComponent($('#obituary-top div.top-info-middle div.top-full-name > h1').text());
      const fhName = encodeURIComponent(window.ozly.getDataLayerValue('siteInfo.fhName'));

      const regex = /^(?:https?:\/\/)?([^:\/\n?]+(?:\.[^:\/\n?]+)*)/i;
      const flwDmn = encodeURIComponent(regex.exec($('#topObitsNav  div.top-obit-nav__btns a:contains("Send")').attr('href'))[1]);
      var productsOffered = encodeURIComponent("Flowers&Tree");
      var brandName = encodeURIComponent(window.ozly.getDataLayerValue('siteInfo.brandName'));
  
			// Get hostname
			var hostname = window.location.hostname;
			var domain = hostname.includes('www.') ? hostname.split('www.')[1] : hostname;
			domain = encodeURIComponent(domain);


      const bkDmn = encodeURIComponent(MaterialData.domainGuid);
      const foodLink = `https://shop.tributetechnology.io/pages/home?decId=${dId}&decName=${dName}&fhName=${fhName}&storeDmn=${flwDmn}&bkDmn=${bkDmn}&decImg=${dImg}&utm_term=${dId}&utm_medium=referral&utm_content=${productsOffered}&utm_source=${domain}&utm_campaign=FRZ-spoonful`;

      let refNum;
      if(window.ozly.getDataLayerValue('pageInfo.productsOffered').includes('Flowers')){
        refNum = '7451385.4c0bb8';
      }else{
        refNum = '7451394.05a717';
      }

      let calledBack = false;
      dataLayer.push({
          'event': 'ga4Event',
          'category': 'Obituary',
          'action': 'Obit - Meals Obit CTA Click - #CRO-547',
          'label': 'Send a Meal Button Click',
          'eventCallback': function () {
              if (!calledBack) {
                  calledBack = true;
                  // window.location.href = foodLink;
                   window.open(foodLink, '_self');
                  //window.open(`https://www.spoonfulofcomfort.com/collections/gifts-of-care?rfsn=${refNum}&utm_medium=flowerstrees&fh=${window.ozly.getDataLayerValue('siteInfo.fhName')}&dn=${$('#obituary-top div.top-full-name > h1').text()}`);
              }
          }
      });
    };

    const addButton = function () {

      $('#topObitsNav div.top-obit-nav__btns-front > *').last().before('<button class="top-obit-nav__btn btn-material meal-red">Send a Meal</button>');

      $('#primary-mobile-nav > div').removeClass('mobile-nav--full-width');

      const newButton = $('<div class="mobile-nav__flex-item"><button class="top-obit-nav__btn btn-material meal-red">Send a Meal</button></div>');
      [...$('#primary-mobile-nav > div:nth-child(1)')[0].attributes].forEach(attr => {
          if (attr.nodeName.includes('data')) {
              newButton.attr(attr.nodeName, attr.nodeValue)
          }
      });

      $('#primary-mobile-nav > div:nth-child(2)').after(newButton);
      $('#topObitsNav div.top-obit-nav__btns-front > .meal-red').click(onButtonClick);
      $('#primary-mobile-nav  .meal-red').click(onButtonClick);
      $('#topObitsNav > div > div > div.top-obit-nav__btns > div > div > a:contains("Plant")').text('Plant a Tree');


    };
		
    const moveShare = function () {
      const shareButtonElm = $('#primary-mobile-nav > div > a:contains("Share")').parent();
      shareButtonElm.addClass("hide");
      $('#primary-mobile-nav > div > a:contains("Plant")').text('Plant a Tree');
    };
    
    // Check if meal buttons are already there
    setTimeout(function () {
      if ($('.meal-red').length === 0) {
        addButton();
        moveShare();
      }
    });
  });
});
